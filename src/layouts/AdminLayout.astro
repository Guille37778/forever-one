---
interface Props {
  title: string;
  activeNav?: string;
  user?: { email: string };
}

const { title, activeNav = '', user } = Astro.props;
---
<!DOCTYPE html>
<html lang="es" data-admin="true">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} — Atelier Forever One</title>
  <link rel="icon" type="image/png" href="/logo_circular.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box !important; }

    :root {
      --gold: #B8860B;
      --gold-light: #ffd700;
      --gold-pale: #f3cf7a;
      --black: #0a0a0a;
      --dark: #111;
      --sidebar-w: 260px;
      --cream: #FAF9F6;
    }

    body {
      background: var(--cream) !important;
      color: #1a1a1a !important;
      font-family: 'Montserrat', sans-serif;
      min-height: 100vh;
      width: 100%;
      margin: 0;
      display: flex;
    }

    /* ─── SIDEBAR ──────────────────────────────── */
    .sidebar {
      width: var(--sidebar-w);
      min-height: 100vh;
      background: var(--black);
      border-right: 1px solid rgba(184,134,11,0.15);
      position: fixed;
      top: 0; left: 0; bottom: 0;
      display: flex;
      flex-direction: column;
      z-index: 100;
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    body.sidebar-hidden .sidebar {
      transform: translateX(-100%);
    }

    .sidebar-logo {
      padding: 2rem 1.75rem;
      border-bottom: 1px solid rgba(184,134,11,0.12);
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .logo-icon {
      width: 44px; height: 44px;
      background: linear-gradient(135deg, #8B6508 0%, #B8860B 30%, #f3cf7a 55%, #B8860B 80%, #8B6508 100%);
      background-size: 200% auto;
      animation: logoShine 4s linear infinite;
      -webkit-mask-image: url('/logo_circular.png');
      -webkit-mask-size: contain;
      mask-image: url('/logo_circular.png');
      mask-size: contain;
      filter: drop-shadow(0 0 12px rgba(184,134,11,0.5));
    }

    @keyframes logoShine { to { background-position: 200% center; } }

    .logo-brand { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 700; font-style: italic; color: white; }
    .logo-brand span { background: linear-gradient(135deg, #B8860B, #f3cf7a, #B8860B); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .logo-sub { font-size: 7px; letter-spacing: 0.4em; text-transform: uppercase; color: rgba(184,134,11,0.5); font-weight: 500; }

    .nav-section { padding: 1.5rem 0; flex: 1; overflow-y: auto; }
    .nav-label { font-size: 8px; letter-spacing: 0.35em; text-transform: uppercase; color: rgba(255,255,255,0.2); padding: 0 1.75rem; margin-bottom: 0.75rem; font-weight: 700; }
    .nav-item { display: flex; align-items: center; gap: 0.875rem; padding: 0.75rem 1.75rem; font-size: 10px; text-transform: uppercase; color: rgba(255,255,255,0.4); text-decoration: none; transition: all 0.25s; border-left: 2px solid transparent; font-weight: 500; }
    .nav-item:hover { color: rgba(255,255,255,0.85); background: rgba(184,134,11,0.05); }
    .nav-item.active { color: var(--gold-light); background: rgba(184,134,11,0.08); border-left-color: var(--gold); }

    /* Footer ULTRA-MINIMALISTA */
    .sidebar-footer { padding: 1.25rem 1.75rem; border-top: 1px solid rgba(255,255,255,0.05); background: transparent; }
    .user-email { font-size: 8px; color: rgba(184,134,11,0.4); word-break: break-all; letter-spacing: 0.05em; font-weight: 500; margin-bottom: 0.75rem; display: block; text-align: center; }
    .logout-btn { font-size: 9px; text-transform: uppercase; color: rgba(255,255,255,0.3); background: transparent; border: 1px solid rgba(255,255,255,0.05); border-radius: 6px; padding: 0.5rem; cursor: pointer; width: 100%; transition: all 0.3s; font-weight: 700; }
    .logout-btn:hover { border-color: rgba(220, 38, 38, 0.3); color: #f87171; }

    /* ─── MAIN ──────────────────────────────────── */
    .admin-main {
      margin-left: var(--sidebar-w);
      flex: 1;
      min-height: 100vh;
      background: var(--cream);
      width: auto;
      max-width: 100%;
      transition: margin-left 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    body.sidebar-hidden .admin-main { margin-left: 0; }
    
    .topbar {
      background: white;
      border-bottom: 1px solid rgba(0,0,0,0.07);
      padding: 0 2rem;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    
    .topbar-left { display: flex; align-items: center; gap: 1.25rem; }
    
    /* Botón Hamburguesa de Lujo (Fino y Oro) */
    .hamburger { 
      background: none; border: none; cursor: pointer; color: var(--gold); 
      padding: 0.5rem; display: flex; align-items: center; justify-content: center; 
      transition: opacity 0.3s;
    }
    .hamburger:hover { opacity: 0.5; }

    .topbar-title { font-family: 'Playfair Display', serif; font-size: 1.25rem; font-style: italic; color: #1a1a1a; }
    .topbar-badge { font-size: 8px; text-transform: uppercase; background: rgba(184,134,11,0.1); color: var(--gold); padding: 4px 12px; font-weight: 600; }

    .page-content { padding: 2.5rem; }

    /* ─── NOTIFICACIONES (AISLADAS) ─────────────── */
    #toast-container { position: fixed; top: 1.5rem; right: 1.5rem; z-index: 999999; pointer-events: none; display: flex; flex-direction: column; gap: 0.75rem; }
    .atelier-toast { pointer-events: auto; background: #0a0a0a !important; border: 1px solid var(--gold) !important; padding: 1rem 1.5rem; border-radius: 8px; color: var(--gold-pale) !important; display: flex; align-items: center; gap: 1rem; box-shadow: 0 10px 30px rgba(0,0,0,0.5); min-width: 280px; animation: toast-pop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
    @keyframes toast-pop { from { opacity: 0; transform: translateY(-10px) scale(0.9); } to { opacity: 1; transform: translateY(0) scale(1); } }
    .atelier-toast.fade-out { animation: toast-out 0.3s ease forwards; }
    @keyframes toast-out { to { opacity: 0; transform: scale(0.9); } }
    .toast-msg { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }

    @media (max-width: 1024px) {
      .sidebar { transform: translateX(-100%); }
      .admin-main { margin-left: 0 !important; }
      body.sidebar-mobile-open .sidebar { transform: translateX(0); }
    }
  </style>
</head>
<body>

  <div id="toast-container"></div>

  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon"></div>
      <div class="logo-text">
        <div class="logo-brand">Forever <span>One</span></div>
        <div class="logo-sub">Atelier Privado</div>
      </div>
    </div>
    <nav class="nav-section">
      <p class="nav-label">Gestión</p>
      <a href="/admin/dashboard" class={`nav-item ${activeNav === 'dashboard' ? 'active' : ''}`}>Panel Principal</a>
      <a href="/admin/products" class={`nav-item ${activeNav === 'products' ? 'active' : ''}`}>Inventario</a>
      <a href="/admin/subcategories" class={`nav-item ${activeNav === 'subcategories' ? 'active' : ''}`}>Categorización</a>
      <a href="/admin/orders" class={`nav-item ${activeNav === 'orders' ? 'active' : ''}`}>Pedidos</a>
      <a href="/admin/customers" class={`nav-item ${activeNav === 'customers' ? 'active' : ''}`}>Clientes</a>

      <p class="nav-label" style="margin-top:1.5rem;">Reportes</p>
      <a href="/admin/analytics" class={`nav-item ${activeNav === 'analytics' ? 'active' : ''}`}>Analíticas Pro</a>
      
      <p class="nav-label" style="margin-top:1.5rem;">Sistema</p>
      <a href="/" target="_blank" class="nav-item">Ver Sitio Público</a>
    </nav>
    
    <div class="sidebar-footer">
      {user && <span class="user-email">{user.email}</span>}
      <form action="/admin/logout" method="POST">
        <button type="submit" class="logout-btn">Finalizar Sesión</button>
      </form>
    </div>
  </aside>

  <main class="admin-main">
    <header class="topbar">
      <div class="topbar-left">
        <button class="hamburger" onclick="toggleSidebar()" aria-label="Menu">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="7" x2="19" y2="7"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <line x1="5" y1="17" x2="19" y2="17"></line>
          </svg>
        </button>
        <h1 class="topbar-title">{title}</h1>
      </div>
      <span class="topbar-badge">Nodo — {title}</span>
    </header>
    <section class="page-content">
      <slot />
    </section>
  </main>

  <script is:inline>
    if (localStorage.getItem('sidebar-hidden') === 'true' && window.innerWidth > 1024) {
      document.body.classList.add('sidebar-hidden');
    }

    function toggleSidebar() {
      const body = document.body;
      if (window.innerWidth <= 1024) {
        body.classList.toggle('sidebar-mobile-open');
      } else {
        body.classList.toggle('sidebar-hidden');
        localStorage.setItem('sidebar-hidden', body.classList.contains('sidebar-hidden').toString());
      }
    }

    window.showToast = function(message, type = 'success') {
      const container = document.getElementById('toast-container');
      if (!container) return;
      const toast = document.createElement('div');
      toast.className = 'atelier-toast';
      const icon = type === 'success' 
        ? `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>`
        : `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`;
      
      toast.innerHTML = `<div style="color:var(--gold); display:flex;">${icon}</div><div class="toast-msg">${message}</div>`;
      container.appendChild(toast);
      setTimeout(() => {
        toast.classList.add('fade-out');
        setTimeout(() => toast.remove(), 400);
      }, 4000);
    };
  </script>
</body>
</html>
