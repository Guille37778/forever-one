---
import { ClientRouter } from 'astro:transitions';
import CartDrawer from '../components/CartDrawer.astro';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Forever One | Luxury Experience - High-End Fashion House" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href={`${base}/logo_circular.png`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- Google Fonts -->
		<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Inter:wght@300;400;700&family=Montserrat:wght@300;400;700;900&display=swap" rel="stylesheet">
		
		<style>
			/* ── FORZAR VISIBILIDAD TOTAL ─────────────────────── */
			[data-aos] {
				opacity: 1 !important;
				visibility: visible !important;
				transform: none !important;
			}
		</style>
		
		<ClientRouter />
	</head>
	<body class="bg-black text-white font-sans antialiased uppercase tracking-widest"
		x-data="{ mobileMenuOpen: false, atTop: true }"
		:class="{ 'overflow-hidden': mobileMenuOpen }"
		@scroll.window="atTop = (window.pageYOffset > 50 ? false : true)">

		<slot />
		<CartDrawer />
		
		<!-- Marcador de diagnóstico para confirmar renderizado completo -->
		<div style="display:none">FO1</div>
	</body>
</html>

<style is:global>
	[x-cloak] { display: none !important; }
</style>
