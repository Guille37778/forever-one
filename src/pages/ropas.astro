---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import { supabase } from '../lib/supabase';

// Fetch products from Supabase
const { data: productsData } = await supabase
  .from('products')
  .select('*, subcategories(name, slug), collections(name), variants(stock_quantity)')
  .order('created_at', { ascending: false });

const products = productsData?.map((p: any) => ({
  id: p.id,
  nombre: p.name,
  descripcion: p.description,
  precio: p.price,
  imagen: p.image_urls?.[0] || '',
  stock: p.variants?.reduce((sum: number, v: any) => sum + (v.stock_quantity || 0), 0) || 0,
  category: p.category,
  subcategory_name: p.subcategories?.name,
  subcategory_slug: p.subcategories?.slug,
  coleccion: p.collections?.name,
  categoria_label: p.category === 'ropa' ? 'Prenda' : 'Accesorio'
})) || [];

// Get dollar rate
const { data: settings } = await supabase
  .from('site_settings')
  .select('value')
  .eq('key', 'bcv_usd_rate')
  .single();

const dollarRate = parseFloat(settings?.value || '0');

// URL params for filtering
const cat = Astro.url.searchParams.get('cat') || 'Todos';
const sub = Astro.url.searchParams.get('sub') || '';
---

<Layout title="Forever One | Colección Exclusiva">
    <Header />
    <main id="shop-root" 
          data-products={JSON.stringify(products)} 
          data-dollar-rate={dollarRate}
          data-url-cat={cat}
          data-url-sub={sub}>
        
        <Hero 
            title="Viste con" 
            highlight="Distinción" 
            subtitle="Explore nuestra selección de piezas exclusivas diseñadas para elevar su estilo."
            image="https://images.unsplash.com/photo-1441984904996-e0b6ba687e04?auto=format&fit=crop&q=80&w=2000"
        />

        <div class="bg-[#F9F8F6] min-h-screen">
            <!-- Filter Section -->
            <div class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gold/10">
                <div class="max-w-screen-2xl mx-auto px-6 lg:px-12 py-6">
                    <div class="flex flex-col md:flex-row gap-8 justify-between items-center">
                        <div class="flex gap-2 overflow-x-auto pb-2 md:pb-0 no-scrollbar w-full md:w-auto">
                            <button id="cat-btn-todos" onclick="window.__setCategory('Todos')" class="cat-btn active px-6 py-2 border-b-2 border-gold text-gold text-[9px] uppercase tracking-[0.6em] font-black transition-all duration-500 whitespace-nowrap">Todos</button>
                            <button id="cat-btn-ropa" onclick="window.__setCategory('ropa')" class="cat-btn px-6 py-2 border-b-2 border-transparent text-slate-400 hover:text-black text-[9px] uppercase tracking-[0.6em] font-black transition-all duration-500 whitespace-nowrap">Prendas</button>
                            <button id="cat-btn-accesorios" onclick="window.__setCategory('accesorios')" class="cat-btn px-6 py-2 border-b-2 border-transparent text-slate-400 hover:text-black text-[9px] uppercase tracking-[0.6em] font-black transition-all duration-500 whitespace-nowrap">Accesorios</button>
                        </div>

                        <div class="relative w-full md:w-96 group">
                            <input 
                                type="text" 
                                id="search-input"
                                oninput="window.__showSuggestions(this.value)"
                                onblur="setTimeout(window.__hideSuggestions, 200)"
                                placeholder="Buscar en el Atelier..."
                                class="w-full bg-[#f0ede8] border-none text-slate-900 text-[10px] uppercase tracking-[0.3em] font-black px-12 py-4 rounded-full focus:ring-1 focus:ring-gold/30 transition-all placeholder:text-slate-400"
                            />
                            <svg class="absolute left-5 top-1/2 -translate-y-1/2 w-4 h-4 text-gold/40 group-focus-within:text-gold transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                            </svg>
                            <!-- Sugerencias Dropdown -->
                            <div id="search-suggestions" class="absolute top-full left-0 right-0 mt-3 bg-white border border-gold/10 rounded-2xl shadow-2xl overflow-hidden z-[100] hidden flex-col"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Products Section -->
            <section class="max-w-screen-2xl mx-auto px-6 lg:px-12 py-20 lg:py-32">
                <div id="shop-content">
                    <!-- Grid Editorial -->
                    <div id="product-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-10 gap-y-16 min-h-[500px]">
                        <!-- JS will populate this -->
                    </div>

                    <div id="loading-spinner" class="flex justify-center py-20">
                        <div class="w-12 h-12 border-2 border-yellow-600 border-t-transparent rounded-full animate-spin"></div>
                    </div>
                    
                    <div id="empty-state" class="hidden text-center py-32 opacity-80 italic">
                        <div class="max-w-xs mx-auto">
                            <svg class="w-12 h-12 mx-auto mb-6 text-gold/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9.172 9.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            <p id="empty-state-msg" class="text-[10px] uppercase tracking-[0.4em] font-black text-slate-500 mb-4">No hay productos disponibles en este momento</p>
                            <button id="clear-filters-btn" onclick="window.__clearFilters()" class="hidden text-gold text-[8px] uppercase tracking-[0.3em] font-black border-b border-gold pb-1 hover:border-transparent transition-all">Limpiar Búsqueda</button>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <!-- Dollar Widget -->
        <div id="dollar-widget" 
             style={`position:fixed !important; left:25px !important; bottom:25px !important; z-index:1500 !important; cursor:default;`}>
            <div style="background:#000000; border-radius:10px; padding:12px 18px; 
                        display:flex; align-items:center; gap:14px; 
                        box-shadow:0 20px 40px -10px rgba(0,0,0,0.8);
                        border: 1px solid rgba(255,255,255,0.03);">
                <!-- Icon Circle -->
                <div style="width:36px; height:36px; border-radius:50%; border:1px solid rgba(184,134,11,0.35); 
                            display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <span style="color:#B8860B; font-weight:900; font-size:15px; font-family: 'Cinzel', serif;">$</span>
                </div>
                <!-- Labels -->
                <div style="display:flex; flex-direction:column; gap:3px;">
                    <span style="font-size:8px; font-weight:900; color:#B8860B; text-transform:uppercase; letter-spacing:0.2em; line-height:1; opacity:0.8;">
                        Tasa BCV + 1%
                    </span>
                    <span style="font-size:18px; font-weight:900; color:#fff; text-transform:uppercase; font-style:italic; line-height:1; font-family: 'Cinzel', serif; letter-spacing: 0.04em;">
                        Bs. {dollarRate.toFixed(2)}
                    </span>
                </div>
            </div>
        </div>

        <style>
            @font-face {
                font-family: 'Cinzel';
                src: url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&display=swap');
            }
        </style>
    </main>

    <script is:inline>
    (function() {
        // ── State ──────────────────────────────────────────────────────────────────
        let products = [];
        let dollarRate = 0;
        
        let activeCategory = 'Todos';
        let activeSubcategory = '';
        let searchQuery = '';

        // ── Hero Update Logic ──────────────────────────────────────────────────────
        function __updateHeroText(title, highlight) {
            const titleEl = document.getElementById('hero-title');
            const highlightEl = document.getElementById('hero-highlight');
            if (titleEl && highlightEl) {
                if (titleEl.firstChild) titleEl.firstChild.textContent = title + ' ';
                highlightEl.textContent = highlight;
            }
        }

        function refreshHero() {
            if (activeSubcategory) {
                const p = products.find(p => p.subcategory_slug === activeSubcategory);
                const subName = (p ? p.subcategory_name : activeSubcategory).trim();
                const words = subName.split(/\s+/);
                
                if (words.length > 1) {
                    const first = words[0];
                    const rest = words.slice(1).join(' ');
                    __updateHeroText(first, rest);
                } else {
                    __updateHeroText('', subName);
                }
            } else {
                __updateHeroText('Viste con', 'Distinción');
            }
        }

        // ── Helpers ────────────────────────────────────────────────────────────────
        function getNum(val) {
            if (typeof val === 'number') return val;
            const clean = String(val || '0').replace(',', '.').replace(/[^\d.]/g, '');
            return parseFloat(clean) || 0;
        }

        function el(id) { return document.getElementById(id); }

        window.__setCategory = function(cat) {
            activeCategory = cat;
            activeSubcategory = '';
            
            document.querySelectorAll('.cat-btn').forEach(b => {
                const id = b.id;
                const isActive = (cat === 'Todos' && id === 'cat-btn-todos') || (id === 'cat-btn-' + cat);
                b.className = isActive
                    ? 'cat-btn active px-6 py-2 border-b-2 border-gold text-gold text-[9px] uppercase tracking-[0.6em] font-black transition-all duration-500'
                    : 'cat-btn px-6 py-2 border-b-2 border-transparent text-slate-400 hover:text-black text-[9px] uppercase tracking-[0.6em] font-black transition-all duration-500';
            });
            
            const url = new URL(window.location.href);
            if (cat !== 'Todos') url.searchParams.set('cat', cat);
            else url.searchParams.delete('cat');
            url.searchParams.delete('sub');
            window.history.pushState({}, '', url);

            refreshHero();
            renderGrid();
        };

        window.__setSubcategory = function(slug) {
            activeSubcategory = slug;
            activeCategory = 'Todos';
            
            document.querySelectorAll('.cat-btn').forEach(b => {
                b.className = 'cat-btn px-6 py-2 border-b-2 border-transparent text-slate-400 hover:text-black text-[9px] uppercase tracking-[0.6em] font-black transition-all duration-500';
            });

            const url = new URL(window.location.href);
            url.searchParams.delete('cat');
            url.searchParams.set('sub', slug);
            window.history.pushState({}, '', url);

            refreshHero();
            renderGrid();
        };

        window.__setSearch = function(val) {
            searchQuery = val.toLowerCase().trim();
            renderGrid();
        };

        window.__showSuggestions = function(val) {
            const query = val.toLowerCase().trim();
            const box = el('search-suggestions');
            if(!box) return;
            if(!query) {
                box.style.display = 'none';
                return;
            }

            const validProducts = products.filter(p => p.category && p.category.toLowerCase() !== 'general');
            const subcats = Array.from(new Set(validProducts.map(p => p.subcategory_name))).filter(Boolean);
            const matchedCats = subcats.filter(c => c.toLowerCase().includes(query)).slice(0, 3);
            const matchedProds = validProducts.filter(p => p.nombre.toLowerCase().includes(query)).slice(0, 5);

            if(matchedCats.length === 0 && matchedProds.length === 0) {
                box.style.display = 'none';
                return;
            }

            let html = '';
            if(matchedCats.length > 0) {
                html += `<div class="px-5 py-2 bg-[#f9f9f9] border-b border-gold/10 flex items-center gap-2 text-[8px] uppercase tracking-[0.2em] font-black text-[#B8860B]/70">Sugerencias de Categorías</div>`;
                html += matchedCats.map(c => `
                    <button onclick="window.__setSubcatByName('${c}')" class="w-full text-left px-5 py-3 hover:bg-gold/5 border-b border-gold/10 flex items-center gap-3 transition-colors cursor-pointer group">
                        <svg class="w-3.5 h-3.5 text-gold/60 group-hover:text-gold transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                        <span class="text-xs font-black uppercase italic tracking-widest text-slate-600 group-hover:text-black transition-colors">${c}</span>
                    </button>
                `).join('');
            }
            if(matchedProds.length > 0) {
                html += `<div class="px-5 py-2 bg-[#f9f9f9] border-b border-gold/10 flex items-center gap-2 text-[8px] uppercase tracking-[0.2em] font-black text-[#B8860B]/70">Prendas Encontradas</div>`;
                html += matchedProds.map(p => `
                    <button onclick="window.__selectProduct('${p.id}')" class="w-full text-left px-5 py-3 hover:bg-gold/5 flex items-center gap-4 transition-colors border-b border-gold/10 cursor-pointer group">
                        <img src="${p.imagen}" class="w-10 h-10 object-cover rounded-sm border border-gold/20 flex-shrink-0" onerror="this.src='https://images.unsplash.com/photo-1441984904996-e0b6ba687e04?q=80&w=100'">
                        <div class="flex-1 min-w-0">
                            <h4 class="text-[11px] font-black italic uppercase tracking-wider text-black truncate">${p.nombre}</h4>
                            <p class="text-[9px] uppercase tracking-widest text-gold font-bold mt-1">$${p.precio}</p>
                        </div>
                    </button>
                `).join('');
            }

            box.innerHTML = html;
            box.style.display = 'flex';
        };

        window.__hideSuggestions = function() {
            const box = el('search-suggestions');
            if(box) box.style.display = 'none';
        };

        window.__setSubcatByName = function(name) {
            const prod = products.find(p => p.subcategory_name === name);
            if(prod) {
                window.__clearFilters();
                window.__setSubcategory(prod.subcategory_slug);
            }
            const input = el('search-input');
            if(input) input.value = '';
            window.__hideSuggestions();
            el('product-grid').scrollIntoView({ behavior: 'smooth', block: 'start' });
        };

        window.__selectProduct = function(id) {
            const prod = products.find(p => p.id === id);
            if(prod) {
                const input = el('search-input');
                if(input) input.value = prod.nombre;
                activeCategory = 'Todos';
                activeSubcategory = '';
                window.__setSearch(prod.nombre);
            }
            window.__hideSuggestions();
            el('product-grid').scrollIntoView({ behavior: 'smooth', block: 'start' });
        };

        window.__clearFilters = function() {
            activeCategory = 'Todos';
            activeSubcategory = '';
            searchQuery = '';
            const searchInput = el('search-input');
            if (searchInput) searchInput.value = '';
            
            const url = new URL(window.location.href);
            url.searchParams.delete('cat');
            url.searchParams.delete('sub');
            window.history.pushState({}, '', url);

            window.__setCategory('Todos');
        };

        function renderGrid() {
            const grid = el('product-grid');
            const emptyState = el('empty-state');
            const emptyMsg = el('empty-state-msg');
            const clearBtn = el('clear-filters-btn');
            if (!grid) return;

            const visible = products.filter(p => {
                const matchesCategory = activeCategory === 'Todos' || p.category === activeCategory;
                const matchesSubcategory = !activeSubcategory || p.subcategory_slug === activeSubcategory;
                const matchesSearch = !searchQuery || 
                                     p.nombre.toLowerCase().includes(searchQuery) || 
                                     (p.descripcion && p.descripcion.toLowerCase().includes(searchQuery)) ||
                                     (p.subcategory_name && p.subcategory_name.toLowerCase().includes(searchQuery));
                return matchesCategory && matchesSubcategory && matchesSearch;
            });

            if (visible.length === 0) {
                grid.innerHTML = '';
                if (emptyState) {
                    emptyState.classList.remove('hidden');
                    if (searchQuery) {
                        emptyMsg.textContent = 'No se encontró ningún resultado para "' + searchQuery + '"';
                        clearBtn.classList.remove('hidden');
                    } else {
                        emptyMsg.textContent = 'No hay productos disponibles en esta categoría';
                        clearBtn.classList.add('hidden');
                    }
                }
                return;
            }
            
            if (emptyState) emptyState.classList.add('hidden');

            grid.innerHTML = visible.map(p => {
                const inStock = parseInt(p.stock) > 0;
                const rawPrice = getNum(p.precio);
                const showPrice = rawPrice > 0;
                const priceDisplay = '$' + rawPrice.toFixed(2);
                const bsDisplay = showPrice && dollarRate > 0
                    ? `<span style="font-size:8.5px; color:#ccc; font-weight:600; margin-left:6px; opacity:0.8;">≈ Bs. ${Math.round(rawPrice * dollarRate).toLocaleString()}</span>`
                    : '';

                const btnStyle = inStock
                    ? 'background:#111; color:#fff; cursor:pointer;'
                    : 'background:#e5e7eb; color:#9ca3af; cursor:not-allowed; pointer-events:none;';
                const btnLabel = inStock ? '+ Añadir al Carrito' : 'Sin Stock';
                const btnHoverIn  = inStock ? `this.style.background='#B8860B';` : '';
                const btnHoverOut = inStock ? `this.style.background='#111';` : '';

                return `
                <article data-product-id="${p.id}"
                         style="background:#fff; display:flex; flex-direction:column; overflow:hidden;
                                box-shadow:0 20px 60px rgba(184,134,11,0.2), 0 0 30px rgba(184,134,11,0.08); border:1px solid rgba(184,134,11,0.1); transition:all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);"
                         onmouseenter="this.style.boxShadow='0 30px 80px rgba(184,134,11,0.35), 0 0 40px rgba(184,134,11,0.15)'; this.style.transform='translateY(-10px)';"
                         onmouseleave="this.style.boxShadow='0 20px 60px rgba(184,134,11,0.2), 0 0 30px rgba(184,134,11,0.08)'; this.style.transform='translateY(0)';">

                    <a href="/prenda/${p.id}" style="text-decoration:none; color:inherit; display:flex; flex-direction:column; flex:1;">
                        <div style="position:relative; aspect-ratio:4/5; overflow:hidden; background:#f0ede8; flex-shrink:0;">
                            <img src="${p.imagen}" alt="${p.nombre}" loading="lazy"
                                 style="width:100%; height:100%; object-fit:cover; display:block; transition:transform 0.9s ease;"
                                 onmouseenter="this.style.transform='scale(1.07)'"
                                 onmouseleave="this.style.transform='scale(1)'"
                                 onerror="this.src='https://images.unsplash.com/photo-1441984904996-e0b6ba687e04?q=80&w=400'">

                            <div style="position:absolute; top:10px; left:10px; z-index:2;">
                                <span style="background:rgba(0,0,0,0.85); color:#f3cf7a;
                                             font-size:7px; font-weight:800; text-transform:uppercase;
                                             letter-spacing:0.4em; padding:5px 12px; display:block;
                                             backdrop-filter:blur(4px);">
                                    ${p.categoria_label} ${p.coleccion ? '— ' + p.coleccion : ''}
                                </span>
                            </div>

                            ${!inStock ? `
                            <div style="position:absolute; top:10px; right:10px; z-index:2;">
                                <span style="background:rgba(220,38,38,0.9); color:#fff; font-size:8px; font-weight:700;
                                              text-transform:uppercase; letter-spacing:0.15em;
                                              padding:5px 10px; border-radius:999px; display:block;
                                              white-space:nowrap; backdrop-filter:blur(4px);">
                                    Agotado
                                </span>
                            </div>` : ''}
                        </div>

                        <div style="padding:16px 14px 4px; display:flex; flex-direction:column; gap:6px; flex:1;">
                            <h3 style="margin:0; font-family:'Cinzel',serif; font-weight:900; font-style:italic;
                                       text-transform:uppercase; font-size:0.75rem; line-height:1.2; color:#111;
                                       letter-spacing:0.02em;">
                                ${p.nombre}
                            </h3>
                            <p style="margin:4px 0 0; font-size:10px; color:#666; font-style:italic;
                                      line-height:1.5; font-weight:400;
                                      display:-webkit-box; -webkit-line-clamp:3;
                                      -webkit-box-orient:vertical; overflow:hidden;">
                                ${p.descripcion || ''}
                            </p>
                            <div style="flex:1; min-height:12px;"></div>
                            ${showPrice ? `
                            <div style="border-top:1px solid rgba(184,134,11,0.1); padding-top:12px;
                                        display:flex; align-items:baseline; flex-wrap:wrap; gap:4px;">
                                <span style="font-size:1.25rem; font-weight:900; font-style:italic;
                                             color:#B8860B; line-height:1;">
                                    ${priceDisplay}
                                </span>
                                ${bsDisplay}
                            </div>` : ''}
                        </div>
                    </a>

                    <div style="padding:10px 14px 14px;">
                        <button onclick="window.__addToCart(${JSON.stringify(p).replace(/"/g, '&quot;')})"
                                ${!inStock ? 'disabled' : ''}
                                style="width:100%; padding:14px 8px; border:none; font-size:8.5px;
                                       font-family:'Montserrat',sans-serif; font-weight:900;
                                       text-transform:uppercase; letter-spacing:0.45em;
                                       transition:background 0.25s; ${btnStyle}"
                                onmouseenter="${btnHoverIn}"
                                onmouseleave="${btnHoverOut}">
                            ${btnLabel}
                        </button>
                    </div>
                </article>`;
            }).join('');
        }

        function init() {
            const root = document.getElementById('shop-root');
            if (!root) return;

            try { products = JSON.parse(root.dataset.products || '[]'); } catch(e) {}
            dollarRate = parseFloat(root.dataset.dollarRate || '0');
            
            activeCategory = root.dataset.urlCat || 'Todos';
            activeSubcategory = root.dataset.urlSub || '';

            const spinner = el('loading-spinner');
            if (spinner) spinner.style.display = 'none';
            
            renderGrid();
            refreshHero();
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }

        document.addEventListener('astro:after-swap', () => {
            if (document.getElementById('shop-root')) {
                init();
            }
        });
    })();
    </script>
    <Footer />
</Layout>
