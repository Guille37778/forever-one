---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';

// Fetch dinámico de catálogos desde SheetDB (pestaña 'catalogos')
let catalogs = [];
try {
    const response = await fetch('https://sheetdb.io/api/v1/7j1ofof2js7hk?sheet=catalogos');
    catalogs = await response.json();
} catch (error) {
    console.error("Error cargando catálogos:", error);
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Forever One | Catálogos Exclusivos">
    <Header />
    <main>
        <Hero 
            title="Acceso"
            highlight="Exclusivo"
            subtitle="Nuestras Colecciones"
            tagline="Líneas de Diseño"
            image="https://images.unsplash.com/photo-1558769132-cb1aea458c5e?auto=format&fit=crop&q=80&w=2000"
            showButton={false}
        />

        <!-- Catalog Section -->
        <section id="catalogos" class="py-12 md:py-24 bg-[#F9F8F6]" x-data="{ activeFilter: 'todos' }">
            <div class="max-w-7xl mx-auto px-6">
                
                <div class="flex flex-wrap justify-center items-center gap-2 md:gap-6 mb-10 md:mb-20" data-aos="fade-up">
                    <button @click="activeFilter = 'todos'" 
                        :class="activeFilter === 'todos' ? 'bg-metal-gold text-white border-transparent shadow-lg' : 'bg-white text-[#1A1A1A] border-gold/20'"
                        class="min-w-[80px] md:min-w-[120px] px-4 md:px-8 py-2 md:py-3 border text-[9px] uppercase tracking-[0.3em] md:tracking-[0.4em] font-black transition-all duration-500">Todos</button>
                    
                    <button @click="activeFilter = 'hombre'" 
                        :class="activeFilter === 'hombre' ? 'bg-metal-gold text-white border-transparent shadow-lg' : 'bg-white text-[#1A1A1A] border-gold/20'"
                        class="min-w-[80px] md:min-w-[120px] px-4 md:px-8 py-2 md:py-3 border text-[9px] uppercase tracking-[0.3em] md:tracking-[0.4em] font-black transition-all duration-500">Hombre</button>
                    
                    <button @click="activeFilter = 'mujer'" 
                        :class="activeFilter === 'mujer' ? 'bg-metal-gold text-white border-transparent shadow-lg' : 'bg-white text-[#1A1A1A] border-gold/20'"
                        class="min-w-[80px] md:min-w-[120px] px-4 md:px-8 py-2 md:py-3 border text-[9px] uppercase tracking-[0.3em] md:tracking-[0.4em] font-black transition-all duration-500">Mujer</button>
                    
                    <button @click="activeFilter = 'resort'" 
                        :class="activeFilter === 'resort' ? 'bg-metal-gold text-white border-transparent shadow-lg' : 'bg-white text-[#1A1A1A] border-gold/20'"
                        class="min-w-[80px] md:min-w-[120px] px-4 md:px-8 py-2 md:py-3 border text-[9px] uppercase tracking-[0.3em] md:tracking-[0.4em] font-black transition-all duration-500">Resort</button>
                    
                    <button @click="activeFilter = 'accesorios'" 
                        :class="activeFilter === 'accesorios' ? 'bg-metal-gold text-white border-transparent shadow-lg' : 'bg-white text-[#1A1A1A] border-gold/20'"
                        class="min-w-[80px] md:min-w-[120px] px-4 md:px-8 py-2 md:py-3 border text-[9px] uppercase tracking-[0.3em] md:tracking-[0.4em] font-black transition-all duration-500">Accesorios</button>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 md:gap-8">
                    {Array.isArray(catalogs) && catalogs.length > 0 ? (
                        catalogs.map((catalog) => (
                            <div 
                                x-show={`activeFilter === 'todos' || activeFilter === '${catalog.categoria?.toLowerCase()}'`} 
                                class="group" 
                                data-aos="fade-up"
                            >
                                <div class="relative overflow-hidden bg-white p-2 md:p-3 shadow-sm border border-gold/5">
                                    <img 
                                        src={catalog.imagen} 
                                        alt={catalog.nombre}
                                        class="w-full h-[320px] md:h-[350px] object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 group-hover:scale-105"
                                    />
                                    <div class="absolute top-4 left-4">
                                        <span class="bg-black/80 text-white text-[6px] md:text-[7px] uppercase tracking-[0.2em] md:tracking-[0.3em] px-1.5 md:px-2 py-1">
                                            {catalog.categoria}
                                        </span>
                                    </div>
                                </div>
                                <div class="mt-3 text-center">
                                    <h5 class="text-base md:text-lg font-serif font-black italic text-[#1A1A1A] mb-2 md:mb-3">{catalog.nombre}</h5>
                                    <a 
                                        href={`${base}/catalogo_de_ejemplo.pdf`} 
                                        download={`ForeverOne_Catalogo_${catalog.nombre.replace(/\s+/g, '_')}.pdf`}
                                        class="btn-metal-gold block py-3 md:py-3 text-[9px] uppercase tracking-[0.3em] md:tracking-[0.4em] font-black text-white shadow-lg"
                                    >
                                        Descargar PDF
                                    </a>
                                </div>
                            </div>
                        ))
                    ) : (
                        <div class="col-span-full" data-aos="fade-up">
                            <div class="max-w-xs md:max-w-sm mx-auto group">
                                <div class="relative overflow-hidden bg-white p-2 md:p-3 shadow-sm border border-gold/10">
                                    <img 
                                        src="https://images.unsplash.com/photo-1539109136881-3be0616acf4b?q=80&w=800" 
                                        class="w-full h-[280px] md:h-[400px] object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 hover:scale-105"
                                        alt="Catálogo de Muestra"
                                    />
                                    <div class="absolute top-6 left-6">
                                        <span class="bg-black text-white text-[7px] md:text-[8px] uppercase tracking-[0.3em] md:tracking-[0.4em] px-2 md:px-3 py-1 font-black shadow-2xl">Muestra de Estilo</span>
                                    </div>
                                </div>
                                <div class="mt-4 md:mt-6 text-center">
                                    <h5 class="text-xl md:text-2xl font-serif font-black italic text-[#1A1A1A] mb-3 md:mb-4">Catálogo de Ejemplo</h5>
                                    <p class="text-slate-500 text-xs font-light italic mb-6 md:mb-8 px-4">Esta es una muestra de cómo se verán sus colecciones. Puede descargarla mientras sincroniza su Google Sheet.</p>
                                    <a 
                                        href={`${base}/catalogo_de_ejemplo.pdf`} 
                                        download="ForeverOne_Catalogo.pdf"
                                        class="btn-metal-gold block py-3 md:py-4 text-[9px] md:text-[10px] uppercase tracking-[0.4em] md:tracking-[0.5em] font-black text-white shadow-2xl hover:scale-105 transition-all duration-300"
                                    >
                                        Descargar Muestra VIP
                                    </a>
                                </div>
                            </div>
                        </div>
                    )}
                </div>
            </div>
        </section>

        <!-- VIP Section Redesign: Luminous Editorial Look -->
        <section id="suscripcion-vip" class="py-24 md:py-32 bg-white relative overflow-hidden w-full">
            <div class="max-w-7xl mx-auto px-6 relative z-10">
                <div class="grid grid-cols-1 lg:grid-cols-2 border border-black/[0.05] shadow-[0_30px_100px_rgba(0,0,0,0.05)] bg-white">
                    
                    <!-- Image Side: Left -->
                    <div class="relative h-[400px] lg:h-auto overflow-hidden group">
                        <img 
                            src="https://images.unsplash.com/photo-1549439602-43ebca2327af?auto=format&fit=crop&q=80&w=1200" 
                            alt="VIP Boutique Selection" 
                            class="w-full h-full object-cover transition-transform duration-[3s] ease-out group-hover:scale-105"
                        />
                        <div class="absolute inset-0 bg-gradient-to-r from-black/20 to-transparent"></div>
                    </div>
                    
                    <!-- Content Side: Right -->
                    <div class="p-10 md:p-16 flex flex-col justify-center relative">
                        <div class="mb-6" data-aos="fade-up">
                            <span class="text-gold font-bold tracking-[0.5em] uppercase text-[9px] block mb-4">Privilegio Digital</span>
                            <h3 class="text-2xl md:text-5xl font-serif font-black italic text-black leading-tight tracking-tighter mb-6 pr-6">
                                Primicias <span class="metal-gold-text">en su Móvil</span>
                            </h3>
                            <div class="w-16 h-px bg-gold/40 mb-8"></div>
                            <p class="text-slate-500 text-sm md:text-base font-light italic leading-relaxed max-w-sm mb-10">
                                Únase a nuestra selecta comunidad de WhatsApp. Suscríbase para recibir los nuevos catálogos de 
                                <span class="text-black font-bold">Forever One</span> 
                                antes que cualquier otro canal oficial. Un privilegio reservado para nuestros clientes más distinguidos.
                            </p>
                        </div>
                        
                        <div data-aos="fade-up" data-aos-delay="200">
                            <a href="https://wa.me/584244557693" target="_blank" 
                               class="group relative inline-flex items-center gap-6 py-5 px-10 bg-black overflow-hidden transition-all duration-500 hover:shadow-xl hover:scale-[1.02]">
                                <span class="relative z-10 text-[9px] uppercase tracking-[0.4em] font-black text-white group-hover:text-gold transition-colors duration-500">
                                    Unirse a la Comunidad
                                </span>
                                <div class="absolute inset-0 bg-zinc-900 translate-y-[100%] group-hover:translate-y-0 transition-transform duration-500 ease-out"></div>
                                <svg class="relative z-10 w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.148-.67-1.614-.918-2.213-.242-.588-.487-.51-.67-.51-.172-.001-.371-.001-.57-.001-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>

<style>
    @keyframes kenBurns {
        0% { transform: scale(1) translate(0%, 0%); }
        100% { transform: scale(1.1) translate(-2%, -1%); }
    }
    .animate-kenBurns { animation: kenBurns 20s ease-in-out infinite alternate; }

    .btn-metal-gold {
        background: linear-gradient(135deg, #8B6508 0%, #B8860B 25%, #f3cf7a 50%, #B8860B 75%, #8B6508 100%);
        background-size: 200% auto;
        animation: shineBtn 5s linear infinite;
        transition: transform 0.3s ease;
    }
    .btn-metal-gold:hover { transform: translateY(-2px); }
    @keyframes shineBtn { to { background-position: 200% center; } }
    .bg-metal-gold { background: linear-gradient(135deg, #B8860B 0%, #8B6508 100%); }
</style>
