---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (!accessToken) return Astro.redirect('/admin/login');
const { data: { user }, error } = await supabase.auth.getUser(accessToken);
if (error || !user) return Astro.redirect('/admin/login');

const { count: totalProducts } = await supabase
  .from('products').select('*', { count: 'exact', head: true });

const { count: lowStock } = await supabase
  .from('variants').select('*', { count: 'exact', head: true }).lt('stock_quantity', 5);

const { count: pendingOrders } = await supabase
  .from('orders').select('*', { count: 'exact', head: true }).eq('status', 'verificando');

const { count: totalSubcategories } = await supabase
  .from('subcategories').select('*', { count: 'exact', head: true });

  const { data: settingsData } = await supabase
    .from('site_settings')
    .select('*')
    .in('key', ['bcv_usd_rate', 'delivery_enabled', 'delivery_zones']);

  const rateData = settingsData?.find(s => s.key === 'bcv_usd_rate');
  const deliveryEnabled = settingsData?.find(s => s.key === 'delivery_enabled')?.value === 'true';
  const deliveryZones = settingsData?.find(s => s.key === 'delivery_zones')?.value || 'Yuma, Güigüe';

const stats = {
  totalProducts: totalProducts || 0,
  pendingOrders: pendingOrders || 0,
  totalRevenue: '$0.00',
  lowStock: lowStock || 0,
  subcategories: totalSubcategories || 0,
  bcvRate: rateData?.value || '0.00',
  lastUpdate: rateData?.updated_at ? new Date(rateData.updated_at).toLocaleString('es-VE') : 'Nunca',
  deliveryEnabled,
  deliveryZones
};

// Iconos SVG de Alta Definición (Gold Plated Style)
const Icons = {
  Garment: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.38 3.46L16 2a4 4 0 01-8 0L3.62 3.46a2 2 0 00-1.62 1.96V10a6 6 0 0012 0V5.41"/><path d="M12 21V10"/></svg>`,
  Shipping: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 16h6v4a2 2 0 01-2 2H4a2 2 0 01-2-2v-4h6"/><path d="M20 16v-4a2 2 0 00-2-2H6a2 2 0 00-2 2v4"/><path d="M12 16V10"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg>`,
  Layers: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`,
  Alert: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0zM12 9v4M12 17h.01"/></svg>`,
  Plus: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>`
};
---

<AdminLayout title="Panel Principal" activeNav="dashboard" user={{ email: user.email || '' }}>

  <style>
    .welcome-banner {
      background: linear-gradient(135deg, #0a0a0a 0%, #1a1205 60%, #0a0a0a 100%);
      padding: 2rem 1.5rem;
      margin-bottom: 2rem;
      position: relative;
      overflow: hidden;
      border-radius: 12px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    }
    @media (min-width: 768px) { .welcome-banner { padding: 2.5rem 3rem; margin-bottom: 2.5rem; } }

    .welcome-banner::before {
        content: 'FOREVER';
        position: absolute;
        bottom: -2rem;
        right: -1rem;
        font-family: 'Playfair Display', serif;
        font-size: 8rem;
        color: rgba(184, 134, 11, 0.05);
        font-style: italic;
        pointer-events: none;
    }

    .welcome-label {
      font-size: 9px;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: rgba(184,134,11,0.7);
      margin-bottom: 0.5rem;
      font-weight: 700;
    }

    .welcome-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.75rem;
      font-weight: 700;
      font-style: italic;
      color: white;
      margin-bottom: 0.5rem;
    }
    @media (min-width: 768px) { .welcome-title { font-size: 2rem; } }

    .welcome-title span {
      background: linear-gradient(135deg, #B8860B, #f3cf7a, #B8860B);
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shine 4s linear infinite;
    }

    @keyframes shine { to { background-position: 200% center; } }

    .welcome-sub {
      font-size: 10px;
      color: rgba(255,255,255,0.4);
      letter-spacing: 0.05em;
    }

    /* Stats Grid Refined */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      margin-bottom: 2rem;
    }
    @media (min-width: 1024px) { .stats-grid { grid-template-columns: repeat(4, 1fr); gap: 1.25rem; margin-bottom: 2.5rem; } }

    .stat-card {
      background: white;
      border: 1px solid rgba(184,134,11,0.08);
      border-radius: 16px;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      position: relative;
      box-shadow: 0 4px 15px rgba(0,0,0,0.03);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .stat-card:hover { transform: translateY(-5px); box-shadow: 0 12px 25px rgba(0,0,0,0.05); border-color: rgba(184,134,11,0.2); }

    .stat-label { font-size: 8px; letter-spacing: 0.2em; text-transform: uppercase; color: #999; font-weight: 700; margin-bottom: 4px; }
    .stat-value { font-family: 'Playfair Display', serif; font-size: 1.75rem; font-weight: 900; font-style: italic; color: #111; line-height: 1; }
    @media (min-width: 768px) { .stat-value { font-size: 2.25rem; } }
    .stat-meta { font-size: 9px; color: #B8860B; font-weight: 600; margin-top: 8px; opacity: 0.7; }
    .stat-icon-box { width: 40px; height: 40px; background: #fafafa; border: 1px solid #f0f0f0; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 12px; color: #B8860B; }
    .stat-icon-box :global(svg) { width: 20px; height: 20px; filter: drop-shadow(0 2px 4px rgba(184,134,11,0.2)); }

    /* Rate Card */
    .rate-card { background: #0a0a0a; border: 1px solid rgba(184,134,11,0.15); border-radius: 16px; padding: 1.5rem; margin-bottom: 2rem; display: flex; flex-direction: column; gap: 1.5rem; position: relative; overflow: hidden; box-shadow: 0 15px 40px rgba(0,0,0,0.15); }
    @media (min-width: 768px) { .rate-card { flex-direction: row; justify-content: space-between; align-items: center; padding: 2.5rem 3rem; } }
    .rate-info h3 { font-size: 8px; letter-spacing: 0.4em; text-transform: uppercase; color: #B8860B; margin-bottom: 0.75rem; font-weight: 800; }
    .rate-value { font-family: 'Playfair Display', serif; font-size: 2.75rem; font-weight: 700; font-style: italic; color: white; line-height: 1; }
    .rate-value span { font-size: 1rem; color: rgba(255,255,255,0.3); margin-right: 0.75rem; font-weight: 400; }

    .sync-btn { background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%); border: 1px solid rgba(184,134,11,0.3); color: #f3cf7a; padding: 0.75rem 2rem; font-size: 9px; letter-spacing: 0.25em; text-transform: uppercase; font-weight: 800; border-radius: 10px; cursor: pointer; transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); width: 100%; }
    @media (min-width: 768px) { .sync-btn { width: auto; padding: 1rem 2.5rem; } }
    .sync-btn:hover { background: #B8860B; color: #000; border-color: #f3cf7a; transform: translateY(-2px); box-shadow: 0 10px 20px rgba(184,134,11,0.2); }

    .section-label { font-size: 8px; letter-spacing: 0.5em; text-transform: uppercase; color: #bbb; margin: 2.5rem 0 1.25rem; font-weight: 700; display: flex; align-items: center; gap: 1rem; }
    .section-label::after { content: ''; flex: 1; height: 1px; background: #f0f0f0; }

    .actions-grid { display: grid; grid-template-columns: repeat(1, 1fr); gap: 1rem; }
    @media (min-width: 640px) { .actions-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (min-width: 1024px) { .actions-grid { grid-template-columns: repeat(3, 1fr); gap: 1.25rem; } }
    .action-card { background: white; border: 1px solid rgba(0,0,0,0.04); border-radius: 16px; padding: 1.5rem; display: flex; align-items: center; gap: 1.25rem; text-decoration: none; color: inherit; transition: all 0.3s; box-shadow: 0 4px 10px rgba(0,0,0,0.02); }
    .action-card:hover { border-color: #B8860B; transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.05); }
    .action-icon { width: 52px; height: 52px; background: #fdfaf0; border-radius: 14px; display: flex; align-items: center; justify-content: center; color: #B8860B; }
    .action-icon :global(svg) { width: 22px; height: 22px; }
    .action-name { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: #111; font-weight: 800; margin-bottom: 2px; }
    .action-desc { font-size: 10px; color: #aaa; }

    .status-bar { background: #fafafa; border: 1px solid #f0f0f0; border-radius: 12px; padding: 1rem 1.5rem; font-size: 9px; color: #888; font-weight: 600; letter-spacing: 0.05em; margin-top: 4rem; display: flex; align-items: center; gap: 1rem; }
  </style>

  <!-- Welcome Banner -->
  <div class="welcome-banner">
    <p class="welcome-label">✦ Atelier Privado</p>
    <h2 class="welcome-title">Bienvenida, <span>Nazareth</span></h2>
    <p class="welcome-sub">Sistema Forever One · Gestión y Control de Alta Gama.</p>
  </div>

  <!-- BCV Rate Section -->
  <div class="rate-card">
    <div class="rate-info">
      <h3>Tasa de Cambio Operativa (BCV + 1%)</h3>
      <div class="rate-value"><span>Bs.</span>{stats.bcvRate}</div>
      <p style="font-size: 9px; color: rgba(255,255,255,0.3); margin-top: 0.75rem; letter-spacing: 0.1em;">
        ULTIMA SINCRONIZACION: {stats.lastUpdate}
      </p>
    </div>
    <button id="sync-rate-btn" class="sync-btn">↻ Sincronizar Ahora</button>
  </div>

  <script>
    // NOTA: window.showToast se define en el Layout
    const syncBtn = document.getElementById('sync-rate-btn');
    syncBtn?.addEventListener('click', async () => {
      try {
        if (syncBtn instanceof HTMLButtonElement) {
          syncBtn.disabled = true;
          syncBtn.textContent = '⏱ Sincronizando...';
        }
        
        const response = await fetch('/api/sync-bcv?secret=fo1-secret-bcv-192837');
        const data = await response.json();
        
        if (data.success) {
          (window as any).showToast('Tasa de cambio actualizada con éxito');
          setTimeout(() => window.location.reload(), 1000);
        } else {
          (window as any).showToast(data.error || 'Fallo en la sincronización', 'error');
        }
      } catch (e) {
        (window as any).showToast('Error de enlace con el servidor central', 'error');
      } finally {
        if (syncBtn instanceof HTMLButtonElement) {
          syncBtn.disabled = false;
          syncBtn.textContent = '↻ Sincronizar Ahora';
        }
      }
    });

    // Delivery Save Logic
    const saveSettingsBtn = document.getElementById('save-settings-btn');
    saveSettingsBtn?.addEventListener('click', async () => {
      try {
        if (saveSettingsBtn instanceof HTMLButtonElement) {
          saveSettingsBtn.disabled = true;
          saveSettingsBtn.textContent = 'Guardando...';
        }

        const enabled = (document.getElementById('delivery-toggle') as HTMLInputElement).checked;
        const zones = (document.getElementById('delivery-zones-input') as HTMLTextAreaElement).value;

        const response = await fetch('/api/update-settings', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ enabled, zones })
        });

        const result = await response.json();
        if (!result.success) throw new Error(result.error);
        
        (window as any).showToast('Ajustes de entrega actualizados correctamente');
        setTimeout(() => window.location.reload(), 1500);

      } catch (e: any) {
        (window as any).showToast(e.message || 'Error al actualizar ajustes', 'error');
      } finally {
        if (saveSettingsBtn instanceof HTMLButtonElement) {
          saveSettingsBtn.disabled = false;
          saveSettingsBtn.textContent = 'Confirmar Cambios';
        }
      }
    });
  </script>

  <!-- KPI Stats -->
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-icon-box" set:html={Icons.Garment} />
      <p class="stat-label">Prendas Activas</p>
      <p class="stat-value">{stats.totalProducts}</p>
      <p class="stat-meta">En catálogo</p>
    </div>
    <div class="stat-card">
      <div class="stat-icon-box" set:html={Icons.Shipping} />
      <p class="stat-label">Pedidos Pendientes</p>
      <p class="stat-value">{stats.pendingOrders}</p>
      <p class="stat-meta">En verificación</p>
    </div>
    <div class="stat-card">
      <div class="stat-icon-box" set:html={Icons.Layers} />
      <p class="stat-label">Subcategorías</p>
      <p class="stat-value">{stats.subcategories}</p>
      <p class="stat-meta">Organizadas</p>
    </div>
    <div class="stat-card">
      <div class="stat-icon-box" set:html={Icons.Alert} />
      <p class="stat-label">Stock Crítico</p>
      <p class="stat-value">{stats.lowStock}</p>
      <p class="stat-meta">Reponer pronto</p>
    </div>
  </div>

  <!-- Delivery Settings -->
  <p class="section-label">Ajustes de Entrega</p>
  <div class="settings-card shadow-sm" style="background:white; border-radius:16px; padding:2rem; border: 1px solid rgba(0,0,0,0.04);">
    <div class="toggle-group" style="display:flex; align-items:center; gap:1.5rem; margin-bottom:2rem;">
      <input type="checkbox" id="delivery-toggle" checked={stats.deliveryEnabled} style="width:24px; height:24px; cursor:pointer;" class="accent-[#B8860B]">
      <label for="delivery-toggle" style="font-size:10px; text-transform:uppercase; letter-spacing: 0.2em; color:#111; font-weight:700; cursor:pointer;">Habilitar Delivery local</label>
    </div>
    
    <div class="form-group" style="margin-bottom:2rem;">
      <label style="display:block; font-size:8px; text-transform:uppercase; letter-spacing:0.3em; color:#aaa; margin-bottom:0.75rem; font-weight:700;">Zonas de Reparto Operativas</label>
      <textarea id="delivery-zones-input" style="width:100%; min-height:100px; padding:1.25rem; background:#fcfcfc; border:1px solid #f0f0f0; border-radius:12px; font-size:13px; font-family:inherit; outline:none; transition: all 0.3s;" onfocus="this.style.borderColor='#B8860B'; this.style.background='white';">{stats.deliveryZones}</textarea>
    </div>

    <button id="save-settings-btn" class="save-btn" style="background:#111; color:#B8860B; border:1px solid #222; padding:1.15rem; font-size:9px; letter-spacing:0.4em; text-transform:uppercase; font-weight:800; border-radius:12px; cursor:pointer; width:100%; transition:all 0.3s;">Confirmar Cambios</button>
  </div>

  <!-- Quick Actions -->
  <p class="section-label">Gestión Rápida</p>
  <div class="actions-grid">
    <a href="/admin/products/new" class="action-card">
      <div class="action-icon" set:html={Icons.Plus} />
      <div class="action-info">
        <p class="action-name">Nueva Prenda</p>
        <p class="action-desc">Añadir al Atelier</p>
      </div>
    </a>
    <a href="/admin/subcategories" class="action-card">
      <div class="action-icon" set:html={Icons.Layers} />
      <div class="action-info">
        <p class="action-name">Categorización</p>
        <p class="action-desc">Gestionar Estilos</p>
      </div>
    </a>
    <a href="/admin/orders" class="action-card">
      <div class="action-icon" set:html={Icons.Shipping} />
      <div class="action-info">
        <p class="action-name">Ver Pedidos</p>
        <p class="action-desc">Panel de Compras</p>
      </div>
    </a>
  </div>

  <!-- Status -->
  <div class="status-bar">
    <div style="width:8px; height:8px; border-radius:50%; background:#B8860B; box-shadow:0 0 10px rgba(184,134,11,0.5); animation: pulse 2s infinite;"></div>
    SISTEMA FOREVER ONE — ESTADO: ACTIVO · SESIÓN DE ADMINISTRADOR CIFRADA
  </div>

</AdminLayout>
