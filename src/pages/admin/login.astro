---
import { supabase } from '../../lib/supabase';

const cookie = Astro.request.headers.get('cookie') || '';
const accessToken = cookie.match(/sb-access-token=([^;]+)/)?.[1];
if (accessToken) {
  const { data: { user } } = await supabase.auth.getUser(accessToken);
  if (user) return Astro.redirect('/admin/dashboard');
}

let message = '';
let messageType = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email = form.get('email')?.toString();
  const password = form.get('password')?.toString();

  if (email && password) {
    const { data, error } = await supabase.auth.signInWithPassword({ email, password });
    if (error) {
      message = `Credenciales incorrectas. Por favor verifique e intente de nuevo.`;
      messageType = 'error';
    } else if (data.session) {
      Astro.cookies.set('sb-access-token', data.session.access_token, {
        path: '/', httpOnly: true, sameSite: 'lax',
        secure: Astro.url.protocol === 'https:',
        maxAge: 60 * 60 * 24 * 7
      });
      Astro.cookies.set('sb-refresh-token', data.session.refresh_token, {
        path: '/', httpOnly: true, sameSite: 'lax',
        secure: Astro.url.protocol === 'https:',
        maxAge: 60 * 60 * 24 * 30
      });
      return Astro.redirect('/admin/dashboard');
    }
  }
}
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Entrar al Atelier — Forever One</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html {
      width: 100%;
      margin: 0;
      padding: 0;
    }

    body {
      min-height: 100vh;
      width: 100%;
      margin: 0;
      display: flex;
      flex-direction: column;
      font-family: 'Montserrat', sans-serif;
      background: #0a0a0a;
      overflow-x: hidden;
    }

    @media (min-width: 900px) {
      body { flex-direction: row; }
    }

    /* Left decorative panel */
    .panel-left {
      display: none;
      background: linear-gradient(135deg, #0a0a0a 0%, #1a1205 50%, #080501 100%);
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 4rem;
      position: relative;
      overflow: hidden;
    }

    @media (min-width: 900px) {
      .panel-left { display: flex; flex: 1; }
    }

    .panel-left::before {
      content: 'FO1';
      position: absolute;
      font-family: 'Playfair Display', serif;
      font-size: 20rem;
      font-weight: 900;
      font-style: italic;
      color: rgba(184,134,11,0.04);
      letter-spacing: -0.05em;
      line-height: 1;
      pointer-events: none;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
    }

    .panel-left::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 30% 70%, rgba(184,134,11,0.06) 0%, transparent 60%);
      pointer-events: none;
    }

    .brand-container { text-align: center; position: relative; z-index: 1; }

    /* Gold logo - same CSS mask effect as the website nav */
    .logo-icon {
      width: 96px;
      height: 96px;
      margin: 0 auto 2rem;
      background: linear-gradient(135deg, #8B6508 0%, #B8860B 30%, #f3cf7a 55%, #B8860B 80%, #8B6508 100%);
      background-size: 200% auto;
      animation: goldShine 4s linear infinite;
      -webkit-mask-image: url('/logo_circular.png');
      -webkit-mask-size: contain;
      -webkit-mask-repeat: no-repeat;
      -webkit-mask-position: center;
      mask-image: url('/logo_circular.png');
      mask-size: contain;
      mask-repeat: no-repeat;
      mask-position: center;
      filter: drop-shadow(0 0 24px rgba(184,134,11,0.5));
    }

    @keyframes goldShine { to { background-position: 200% center; } }

    .brand-name {
      font-family: 'Playfair Display', serif;
      font-size: 3rem;
      font-weight: 700;
      font-style: italic;
      color: white;
      line-height: 1;
      margin-bottom: 0.5rem;
    }

    .brand-name span {
      background: linear-gradient(135deg, #B8860B, #f3cf7a, #B8860B);
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: goldShine 4s linear infinite;
    }

    .brand-tagline {
      font-size: 8px;
      letter-spacing: 0.6em;
      text-transform: uppercase;
      color: rgba(184,134,11,0.5);
      font-weight: 500;
    }

    .panel-left-footer {
      position: absolute;
      bottom: 2rem;
      font-size: 8px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.12);
    }

    /* Right login panel */
    .panel-right {
      width: 100%;
      min-height: 100vh;
      background: white;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 3rem 1.5rem;
      position: relative;
    }

    @media (min-width: 900px) {
      .panel-right { width: 480px; padding: 4rem 3.5rem; }
    }

    .panel-right::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 1px;
      background: linear-gradient(to bottom, transparent, rgba(184,134,11,0.25), transparent);
    }

    .login-header { text-align: center; margin-bottom: 3rem; }

    .login-tag {
      font-size: 8px;
      letter-spacing: 0.5em;
      text-transform: uppercase;
      color: #B8860B;
      font-weight: 600;
      margin-bottom: 0.75rem;
    }

    .login-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.75rem;
      font-weight: 700;
      font-style: italic;
      color: #111;
      margin-bottom: 0.35rem;
    }

    .login-subtitle {
      font-size: 10px;
      color: #bbb;
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    .mobile-logo {
      display: block;
      width: 48px;
      height: 48px;
      margin: 0 auto 1.5rem;
      background: linear-gradient(135deg, #8B6508 0%, #B8860B 30%, #f3cf7a 55%, #B8860B 80%, #8B6508 100%);
      background-size: 200% auto;
      animation: goldShine 4s linear infinite;
      -webkit-mask-image: url('/logo_circular.png');
      -webkit-mask-size: contain;
      -webkit-mask-repeat: no-repeat;
      -webkit-mask-position: center;
      mask-image: url('/logo_circular.png');
      mask-size: contain;
      mask-repeat: no-repeat;
      mask-position: center;
    }

    @media (min-width: 900px) {
      .mobile-logo { display: none; }
    }

    /* Form */
    .login-form { width: 100%; }

    .form-group { margin-bottom: 1.5rem; }

    label {
      display: block;
      font-size: 8px;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: #aaa;
      margin-bottom: 0.5rem;
      font-weight: 600;
    }

    input {
      width: 100%;
      padding: 0.875rem 1rem;
      background: white;
      border: 1px solid rgba(0,0,0,0.12);
      color: #111;
      font-family: 'Montserrat', sans-serif;
      font-size: 14px;
      outline: none;
      transition: border-color 0.25s, box-shadow 0.25s;
    }

    input:focus {
      border-color: rgba(184,134,11,0.5);
      box-shadow: 0 0 0 3px rgba(184,134,11,0.07);
    }

    input::placeholder { color: #ccc; }

    .submit-btn {
      width: 100%;
      margin-top: 0.75rem;
      padding: 1rem;
      background: linear-gradient(135deg, #8B6508, #B8860B, #f3cf7a, #B8860B, #8B6508);
      background-size: 200% auto;
      animation: goldShine 4s linear infinite;
      color: #0a0a0a;
      border: none;
      font-family: 'Montserrat', sans-serif;
      font-size: 9px;
      letter-spacing: 0.5em;
      text-transform: uppercase;
      font-weight: 700;
      cursor: pointer;
      transition: opacity 0.3s;
    }

    .submit-btn:hover { opacity: 0.85; }

    .message {
      padding: 0.875rem 1rem;
      font-size: 12px;
      margin-bottom: 1.75rem;
      border-left: 3px solid;
      font-weight: 500;
    }

    .message.success { border-color: #B8860B; background: rgba(184,134,11,0.05); color: #8B6508; }
    .message.error { border-color: #dc2626; background: rgba(220,38,38,0.05); color: #dc2626; }

    .login-footer {
      margin-top: 2.5rem;
      font-size: 9px;
      color: #ccc;
      text-align: center;
      letter-spacing: 0.1em;
    }

    .login-footer a { color: #B8860B; text-decoration: none; transition: color 0.25s; }
    .login-footer a:hover { color: #8B6508; }

    .security-badge {
      position: absolute;
      bottom: 2rem;
      font-size: 8px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #ddd;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    /* Intro Overlay */
    .intro-overlay {
      position: fixed;
      inset: 0;
      background: #0a0a0a;
      z-index: 9999;
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.5s ease;
    }

    .intro-overlay.active {
      display: flex;
      opacity: 1;
    }

    .intro-logo {
      width: 140px;
      height: 140px;
      margin-bottom: 2rem;
      transform: scale(0.8);
      opacity: 0;
      background: linear-gradient(135deg, #8B6508 0%, #B8860B 30%, #f3cf7a 55%, #B8860B 80%, #8B6508 100%);
      background-size: 200% auto;
      animation: goldShine 4s linear infinite, logoEnter 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      -webkit-mask-image: url('/logo_circular.png');
      -webkit-mask-size: contain;
      -webkit-mask-repeat: no-repeat;
      -webkit-mask-position: center;
      mask-image: url('/logo_circular.png');
      mask-size: contain;
      mask-repeat: no-repeat;
      mask-position: center;
      filter: drop-shadow(0 0 32px rgba(184,134,11,0.6));
    }

    .intro-text {
      opacity: 0;
      transform: translateY(20px);
      animation: textEnter 1.5s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
    }

    .intro-loading {
      font-size: 9px;
      letter-spacing: 0.5em;
      text-transform: uppercase;
      color: rgba(184,134,11,0.6);
      margin-top: 2rem;
      opacity: 0;
      animation: textEnter 1.5s cubic-bezier(0.16, 1, 0.3, 1) 1s forwards, pulseLoading 2s linear infinite 2s;
    }

    @keyframes logoEnter {
      to { transform: scale(1); opacity: 1; }
    }
    @keyframes textEnter {
      to { transform: translateY(0); opacity: 1; }
    }
    @keyframes pulseLoading {
      0%, 100% { opacity: 0.5; }
      50% { opacity: 1; }
    }
  </style>
</head>
<body>

  <!-- Left brand panel -->
  <div class="panel-left">
    <div class="brand-container">
      <div class="logo-icon" aria-label="Forever One Logo"></div>
      <h1 class="brand-name">Forever <span>One</span></h1>
      <p class="brand-tagline">Atelier de Lujo ✦ Gestión Exclusiva</p>
    </div>
    <p class="panel-left-footer">Sistema de Administración Privado</p>
  </div>

  <!-- Right login panel -->
  <div class="panel-right">
    <div class="login-header">
      <div class="mobile-logo"></div>
      <p class="login-tag">✦ Acceso Privado</p>
      <h2 class="login-title">Bienvenido</h2>
      <p class="login-subtitle">Identifíquese para continuar</p>
    </div>

    {message && (
      <div class={`message ${messageType}`}>{message}</div>
    )}

    <form method="POST" class="login-form">
      <div class="form-group">
        <label for="email">Correo Electrónico</label>
        <input type="email" id="email" name="email" placeholder="admin@foreverone.com" required autocomplete="email">
      </div>
      <div class="form-group">
        <label for="password">Contraseña</label>
        <input type="password" id="password" name="password" placeholder="••••••••" required autocomplete="current-password">
      </div>
      <button type="submit" class="submit-btn">Entrar al Atelier →</button>
    </form>

    <p class="login-footer">
      ¿Primera vez? <a href="/admin/register">Crear cuenta administrativa</a>
    </p>

    <div class="security-badge">
      🔒 Conexión Segura · Forever One
    </div>
  </div>

  <div class="intro-overlay" id="intro-overlay">
    <div class="intro-logo"></div>
    <h1 class="brand-name intro-text">Forever <span>One</span></h1>
    <p class="intro-loading">Abriendo Puertas del Atelier...</p>
  </div>

  <script>
    const form = document.querySelector('.login-form');
    if (form) {
      form.addEventListener('submit', function(e) {
        const _form = this as HTMLFormElement;
        if (_form.dataset.submitting) return;

        e.preventDefault();
        _form.dataset.submitting = 'true';

        const overlay = document.getElementById('intro-overlay');
        const submitBtn = _form.querySelector('.submit-btn') as HTMLButtonElement;
        
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Autenticando...';
        }

        if (overlay) {
          overlay.classList.add('active');

          try {
            const audio = new Audio('/audio_apertura.mp3');
            audio.play().catch(e => console.log('Error reproduciendo audio:', e));
          } catch (err) {
            console.log('Audio no soportado:', err);
          }

          // Esperar 8 segundos que dura el audio de bienvenida
          setTimeout(() => {
            _form.submit();
          }, 8000);
        } else {
          _form.submit();
        }
      });
    }
  </script>
</body>
</html>
