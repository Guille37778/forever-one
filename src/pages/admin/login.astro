---
import { supabase } from '../../lib/supabase';
export const prerender = false;

const cookie = Astro.request.headers.get('cookie') || '';
const accessToken = cookie.match(/sb-access-token=([^;]+)/)?.[1];
if (accessToken) {
  const { data: { user } } = await supabase.auth.getUser(accessToken);
  if (user) return Astro.redirect('/admin/dashboard');
}

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const email = formData.get('email')?.toString();
    const password = formData.get('password')?.toString();

    if (email && password) {
      const { data, error } = await supabase.auth.signInWithPassword({ email, password });

      if (error || !data.session) {
        return new Response(JSON.stringify({ error: 'Credenciales incorrectas' }), { status: 401 });
      } else {
        const isSecure = Astro.url.protocol === 'https:';
        const accessTokenCookie = `sb-access-token=${data.session.access_token}; Path=/; HttpOnly; SameSite=Lax${isSecure ? '; Secure' : ''}; Max-Age=604800`;
        const refreshTokenCookie = `sb-refresh-token=${data.session.refresh_token}; Path=/; HttpOnly; SameSite=Lax${isSecure ? '; Secure' : ''}; Max-Age=2592000`;

        const headers = new Headers();
        headers.append('Set-Cookie', accessTokenCookie);
        headers.append('Set-Cookie', refreshTokenCookie);
        headers.append('Content-Type', 'application/json');

        return new Response(JSON.stringify({ success: true }), { status: 200, headers });
      }
    }
    return new Response(JSON.stringify({ error: 'Faltan credenciales' }), { status: 400 });
  } catch (e) {
    return new Response(JSON.stringify({ error: 'Error interno' }), { status: 500 });
  }
}
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Entrar al Atelier — Forever One</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html { height: 100%; width: 100%; }

    body {
      min-height: 100vh;
      width: 100%;
      margin: 0;
      display: flex;
      flex-direction: column;
      font-family: 'Montserrat', sans-serif;
      background: #0a0a0a;
      overflow-x: hidden;
    }

    @media (min-width: 900px) {
      body { flex-direction: row; }
    }

    /* Decorative Left Panel */
    .panel-left {
      display: none;
      background: linear-gradient(135deg, #0a0a0a 0%, #1a1205 60%, #080501 100%);
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 4rem;
      position: relative;
      overflow: hidden;
      flex: 5;
    }

    @media (min-width: 900px) {
      .panel-left { display: flex; }
    }

    .panel-left::before {
      content: 'FO1';
      position: absolute;
      font-family: 'Playfair Display', serif;
      font-size: 24rem;
      font-weight: 900;
      font-style: italic;
      color: rgba(184,134,11,0.03);
      letter-spacing: -0.05em;
      line-height: 1;
      pointer-events: none;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
    }

    .brand-container { 
      text-align: center; 
      position: relative; 
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    .logo-icon {
      width: 80px;
      height: 80px;
      margin-bottom: 2rem;
      background: linear-gradient(135deg, #8B6508 0%, #B8860B 30%, #f3cf7a 55%, #B8860B 80%, #8B6508 100%);
      background-size: 200% auto;
      animation: goldShine 4s linear infinite;
      -webkit-mask-image: url('/logo_circular.png');
      -webkit-mask-size: contain;
      -webkit-mask-repeat: no-repeat;
      mask-image: url('/logo_circular.png');
      mask-size: contain;
      filter: drop-shadow(0 0 30px rgba(184,134,11,0.4));
    }

    @media (min-width: 900px) {
      .logo-icon { width: 120px; height: 120px; }
    }

    @keyframes goldShine { to { background-position: 200% center; } }

    .brand-name {
      font-family: 'Playfair Display', serif;
      font-size: 2.5rem;
      font-weight: 700;
      font-style: italic;
      color: white;
      line-height: 1;
      margin-bottom: 0.75rem;
      text-align: center;
    }

    @media (min-width: 900px) {
      .brand-name { font-size: 3.5rem; }
    }

    .brand-name span {
      background: linear-gradient(135deg, #B8860B, #f3cf7a, #B8860B);
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: goldShine 4s linear infinite;
    }

    .brand-tagline {
      font-size: 9px;
      letter-spacing: 0.6em;
      text-transform: uppercase;
      color: rgba(184,134,11,0.6);
      font-weight: 600;
      text-align: center;
      padding-left: 0.6em;
    }

    /* Right Login Panel */
    .panel-right {
      width: 100%;
      min-height: 100vh;
      background: #ffffff;
      background-image: radial-gradient(#f0eee9 0.5px, transparent 0.5px);
      background-size: 20px 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2.5rem 1.75rem;
      position: relative;
    }

    @media (min-width: 900px) {
      .panel-right { width: 480px; padding: 4rem 3.5rem; }
    }

    .login-header { text-align: center; margin-bottom: 3rem; width: 100%; }

    .mobile-logo {
        width: 64px;
        height: 64px;
        margin: 0 auto 1.5rem;
        background: linear-gradient(135deg, #8B6508, #B8860B, #f3cf7a, #B8860B);
        background-size: 200% auto;
        animation: goldShine 4s linear infinite;
        -webkit-mask-image: url('/logo_circular.png');
        -webkit-mask-size: contain;
        -webkit-mask-repeat: no-repeat;
        mask-image: url('/logo_circular.png');
        mask-size: contain;
    }

    @media (min-width: 900px) { .mobile-logo { display: none; } }

    .login-tag {
      font-size: 8px;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: #B8860B;
      font-weight: 800;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
    }

    .login-tag::before, .login-tag::after {
      content: '';
      width: 15px;
      height: 1px;
      background: rgba(184,134,11,0.3);
    }

    .login-title {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      font-weight: 700;
      color: #111;
      margin-bottom: 0.5rem;
      font-style: italic;
    }

    .login-subtitle {
      font-size: 9px;
      color: #aaa;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-weight: 500;
    }

    /* Form */
    .login-form { width: 100%; max-width: 360px; position: relative; }

    .form-group { margin-bottom: 1.5rem; position: relative; }

    label {
      display: block;
      font-size: 8px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #ccc;
      margin-bottom: 0.6rem;
      font-weight: 700;
    }

    input {
      width: 100%;
      padding: 1rem;
      background: #fafafa;
      border: 1px solid #f0f0f0;
      color: #111;
      font-family: 'Montserrat', sans-serif;
      font-size: 14px;
      outline: none;
      transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
      -webkit-appearance: none;
      border-radius: 0;
    }

    input:focus {
      background: white;
      border-color: #B8860B;
      box-shadow: 0 10px 25px rgba(184,134,11,0.06);
      transform: translateY(-2px);
    }

    .submit-btn {
      width: 100%;
      margin-top: 1rem;
      padding: 1.15rem;
      background: #000;
      color: #B8860B;
      border: 1px solid #111;
      font-size: 9px;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      font-weight: 800;
      cursor: pointer;
      transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
      border-radius: 0;
    }

    .submit-btn:hover {
      background: #111;
      color: #f3cf7a;
      box-shadow: 0 15px 35px rgba(0,0,0,0.15);
    }

    @media (max-width: 600px) {
        .submit-btn { padding: 1.25rem; font-size: 10px; }
        input { padding: 1.15rem; }
    }

    .error-box {
      background: #fff5f5;
      color: #c53030;
      border-left: 2px solid #c53030;
      padding: 1rem;
      font-size: 11px;
      margin-bottom: 2rem;
      display: none;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 600;
    }

    .login-footer {
      margin-top: 3.5rem;
      font-size: 9px;
      color: #ccc;
      text-align: center;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .login-footer a { color: #B8860B; text-decoration: none; font-weight: 700; margin-left: 5px; }

    /* Success / Intro Overlay */
    .intro-overlay {
      position: fixed;
      inset: 0;
      background: #0a0a0a;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      transition: all 1s cubic-bezier(0.86, 0, 0.07, 1);
      padding: 2rem;
      text-align: center;
    }

    .intro-overlay.fade-out {
      opacity: 0;
      visibility: hidden;
      transform: scale(1.1);
    }

    .intro-overlay.active {
      opacity: 1;
      visibility: visible;
      transform: scale(1);
    }

    .intro-logo {
      width: 100px;
      height: 100px;
      margin-bottom: 2rem;
      background: linear-gradient(135deg, #8B6508, #B8860B, #f3cf7a, #B8860B);
      background-size: 200% auto;
      animation: goldShine 4s linear infinite;
      -webkit-mask-image: url('/logo_circular.png');
      -webkit-mask-size: contain;
      -webkit-mask-repeat: no-repeat;
      mask-image: url('/logo_circular.png');
      mask-size: contain;
    }

    @media (min-width: 900px) {
      .intro-logo { width: 140px; height: 140px; }
    }

    .success-text {
      color: white;
      font-family: 'Playfair Display', serif;
      font-size: 1.25rem;
      font-style: italic;
      letter-spacing: 0.15em;
      opacity: 0;
      transform: translateY(20px);
      transition: all 0.6s ease forwards;
    }

    @media (min-width: 900px) {
      .success-text { font-size: 1.5rem; letter-spacing: 0.2em; }
    }

    .success-text.show {
      opacity: 1;
      transform: translateY(0);
    }

    .bottom-meta {
      position: absolute;
      bottom: 1.5rem;
      left: 1.5rem;
      right: 1.5rem;
      text-align: center;
      font-size: 7px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #ddd;
    }
  </style>
</head>
<body>

  <!-- Audio de Apertura -->
  <audio id="audio-login" src="/audio_apertura.mp3" preload="auto"></audio>

  <!-- Overlay de Transición -->
  <div class="intro-overlay" id="intro-overlay">
    <div class="intro-logo"></div>
    <div id="status-text" class="success-text">Bienvenida Nazareth</div>
  </div>

  <!-- Panel Izquierdo Decorativo -->
  <div class="panel-left">
    <div class="brand-container">
      <div class="logo-icon"></div>
      <h1 class="brand-name">Forever <span>One</span></h1>
      <p class="brand-tagline">Gestión Exclusiva</p>
    </div>
  </div>

  <!-- Panel Derecho de Login -->
  <div class="panel-right">
    <div id="error-box" class="error-box"></div>

    <div class="login-header">
      <div class="mobile-logo"></div>
      <p class="login-tag">✦ Atelier de Lujo ✦</p>
      <h2 class="login-title">Bienvenido</h2>
      <p class="login-subtitle">Identifíquese para entrar al sistema</p>
    </div>

    <form class="login-form" id="login-form">
      <div class="form-group">
        <label for="email">Correo Electrónico</label>
        <input type="email" id="email" name="email" placeholder="admin@foreverone.com" required>
      </div>
      <div class="form-group">
        <label for="password">Contraseña</label>
        <input type="password" id="password" name="password" placeholder="••••••••" required>
      </div>
      <button type="submit" class="submit-btn" id="submit-btn">Abrir Sistema →</button>
    </form>

    <p class="login-footer">
      ¿Sin acceso? <a href="/admin/register">Solicitar cuenta</a>
    </p>

    <div class="bottom-meta">
      🔒 Encrypted Secure Atelier Node
    </div>
  </div>

  <script>
    // Variable para controlar el estado del script
    (function() {
      // Usar casting para TypeScript
      const overlay = document.getElementById('intro-overlay');
      const statusText = document.getElementById('status-text');
      const audio = document.getElementById('audio-login') as HTMLAudioElement;
      const form = document.getElementById('login-form') as HTMLFormElement;
      const errorBox = document.getElementById('error-box');
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

      // Desvanecer carga inicial
      window.addEventListener('load', () => {
        if (overlay) {
          setTimeout(() => {
            overlay.classList.add('fade-out');
          }, 1500);
        }
      });

      if (form && submitBtn && errorBox && overlay && audio && statusText) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          errorBox.style.display = 'none';
          submitBtn.textContent = 'Verificando Nodo...';
          submitBtn.disabled = true;

          const formData = new FormData(form);
          
          try {
            const response = await fetch(window.location.href, {
              method: 'POST',
              body: formData
            });

            const result = await response.json();

            if (result.success) {
              submitBtn.textContent = 'Acceso Autorizado...';
              
              overlay.classList.remove('fade-out');
              overlay.classList.add('active');
              
              // Seguridad de redirección
              const redirectSafety = setTimeout(() => {
                window.location.href = '/admin/dashboard';
              }, 15000); 

              audio.onended = () => {
                clearTimeout(redirectSafety);
                setTimeout(() => {
                   window.location.href = '/admin/dashboard';
                }, 600);
              };

              try {
                audio.play();
              } catch(e) {
                window.location.href = '/admin/dashboard';
              }

              setTimeout(() => {
                statusText.classList.add('show');
              }, 200);

            } else {
              submitBtn.textContent = 'Abrir Sistema →';
              submitBtn.disabled = false;
              errorBox.textContent = result.error || 'Autenticación Fallida';
              errorBox.style.display = 'block';
            }
          } catch (err) {
            submitBtn.textContent = 'Abrir Sistema →';
            submitBtn.disabled = false;
            errorBox.textContent = 'Error de Enlace de Datos';
            errorBox.style.display = 'block';
          }
        });
      }
    })();
  </script>
</body>
</html>
