---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase, supabaseAdmin } from '../../../lib/supabase';

const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (!accessToken) return Astro.redirect('/admin/login');
const { data: { user }, error: authError } = await supabase.auth.getUser(accessToken);
if (authError || !user) return Astro.redirect('/admin/login');

const { data: collections } = await supabase.from('collections').select('*').eq('is_active', true);
const { data: allSubcategories } = await supabase.from('subcategories').select('*');

let successMessage = '';
let errorMessage = '';

if (Astro.request.method === 'POST') {
    const form = await Astro.request.formData();
    const name = form.get('name')?.toString();
    const description = form.get('description')?.toString();
    const price = parseFloat(form.get('price')?.toString() || '0');
    const collectionId = form.get('collection_id')?.toString() || null;
    const category = form.get('category')?.toString() || 'ropa';
    const subcategoryId = form.get('subcategory_id')?.toString() || null;
    const sizes = form.getAll('sizes[]').map(s => s.toString());
    const imageFiles = form.getAll('image_files') as File[];
    const imageUrls: string[] = [];

    for (const file of imageFiles) {
      if (file.size > 0 && file.name) {
        const fileExt = file.name.split('.').pop();
        const fileName = `${Math.random().toString(36).substring(2)}-${Date.now()}.${fileExt}`;
        const { data: uploadData, error: uploadError } = await supabaseAdmin.storage
          .from('productos')
          .upload(fileName, file);

        if (!uploadError) {
          const { data: { publicUrl } } = supabaseAdmin.storage
            .from('productos')
            .getPublicUrl(fileName);
          imageUrls.push(publicUrl);
        } else {
            console.error('Error uploading image:', uploadError);
        }
      }
    }

    if (!name || !price) {
        errorMessage = 'El nombre y precio son obligatorios.';
    } else {
        const { data: product, error: productError } = await supabaseAdmin
            .from('products')
            .insert({ name, description, price, collection_id: collectionId, category, subcategory_id: subcategoryId, image_urls: imageUrls })
            .select().single();

        if (productError) {
            errorMessage = 'Error al guardar la prenda: ' + productError.message;
        } else {
            if (sizes.length > 0) {
                const variants = sizes.map((size) => ({
                    product_id: product.id,
                    size,
                    stock_quantity: parseInt(form.get(`stock_${size}`)?.toString() || '0')
                }));
                await supabaseAdmin.from('variants').insert(variants);
            }
            return Astro.redirect('/admin/products?created=true');
        }
    }
}

const created = Astro.url.searchParams.get('created') === 'true';
if (created) successMessage = '✦ Prenda añadida al catálogo exitosamente.';
---

<AdminLayout title="Nueva Prenda" activeNav="products" user={{ email: user?.email || '' }}>

  <style>
    /* TITULO SUPERIOR - REFINAMIENTO DISCRETO */
    :global(.topbar-title) {
        font-size: 1rem !important;
        opacity: 0.9;
        letter-spacing: 0.05em;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 9px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #aaa;
      text-decoration: none;
      margin-bottom: 1.75rem;
      transition: color 0.25s;
      font-weight: 600;
    }
    .back-link:hover { color: #B8860B; }

    .page-header {
      margin-bottom: 2rem;
    }
    .page-header p {
      font-size: 8px;
      letter-spacing: 0.45em;
      text-transform: uppercase;
      color: #B8860B;
      font-weight: 600;
      margin-bottom: 0.35rem;
    }
    .page-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      font-weight: 700;
      font-style: italic;
      color: #111;
    }

    .message {
      padding: 1rem 1.25rem;
      font-size: 12px;
      margin-bottom: 1.75rem;
      border-left: 3px solid;
      font-weight: 500;
    }
    .message.success { border-color: #B8860B; background: rgba(184,134,11,0.05); color: #8B6508; }
    .message.error { border-color: #dc2626; background: rgba(220,38,38,0.05); color: #dc2626; }

    .form-card {
      background: white;
      border: 1px solid rgba(0,0,0,0.07);
      padding: 0;
      max-width: 820px;
      overflow: hidden;
    }

    .form-section {
      padding: 2.25rem 2.5rem;
      border-bottom: 1px solid rgba(0,0,0,0.06);
    }
    .form-section:last-of-type { border-bottom: none; }

    .section-label {
      font-size: 8px;
      letter-spacing: 0.45em;
      text-transform: uppercase;
      color: #B8860B;
      font-weight: 700;
      margin-bottom: 1.75rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: rgba(184,134,11,0.15);
    }

    /* ─── GRID ESCRITORIO (70/30) ─── */
    .form-grid-main {
      display: grid;
      grid-template-columns: 2.5fr 1fr;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }
    .form-grid-three {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .form-group { width: 100%; display: flex; flex-direction: column; }

    label {
      display: block;
      font-size: 8px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #999;
      margin-bottom: 0.65rem;
      font-weight: 600;
      text-align: center;
    }

    input[type="text"],
    input[type="number"],
    textarea,
    select {
      width: 100%;
      box-sizing: border-box;
      padding: 0.75rem 1rem;
      background: white;
      border: 1px solid rgba(0,0,0,0.1);
      color: #111;
      font-family: 'Montserrat', sans-serif;
      font-size: 13px;
      outline: none;
      transition: border-color 0.25s, box-shadow 0.25s;
      min-height: 46px;
      text-align: center;
    }

    select { text-align-last: center; }

    input:focus, textarea:focus, select:focus {
      border-color: rgba(184,134,11,0.5);
      box-shadow: 0 0 0 3px rgba(184,134,11,0.05);
    }

    textarea { resize: vertical; min-height: 110px; }

    /* Size checkboxes */
    .sizes-grid {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 0.5rem;
      margin-bottom: 1.25rem;
    }
    .size-item { text-align: center; }
    .size-item input[type="checkbox"] { display: none; }
    .size-label {
      display: block;
      padding: 0.625rem 0.25rem;
      border: 1px solid rgba(0,0,0,0.1);
      font-size: 9px;
      letter-spacing: 0.1em;
      cursor: pointer;
      transition: all 0.25s;
      text-align: center;
      color: #999;
      font-weight: 600;
    }
    .size-label:hover { border-color: rgba(184,134,11,0.3); color: #B8860B; }
    .size-item input[type="checkbox"]:checked + .size-label {
      border-color: #B8860B;
      background: rgba(184,134,11,0.08);
      color: #B8860B;
    }

    .stock-inputs { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem; }
    .stock-item label { font-size: 8px; color: #aaa; }

    /* Form footer */
    .form-footer {
      padding: 1.75rem 2.5rem;
      background: rgba(0,0,0,0.02);
      border-top: 1px solid rgba(0,0,0,0.06);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .submit-btn {
      padding: 0.875rem 2.5rem;
      background: linear-gradient(135deg, #8B6508, #B8860B, #f3cf7a, #B8860B, #8B6508);
      background-size: 200% auto;
      animation: shine 4s linear infinite;
      color: #0a0a0a;
      border: none;
      font-family: 'Montserrat', sans-serif;
      font-size: 9px;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      font-weight: 700;
      cursor: pointer;
      transition: opacity 0.3s;
      min-height: 48px;
    }
    .submit-btn:hover { opacity: 0.85; }

    @keyframes shine { to { background-position: 200% center; } }

    .cancel-link {
      font-size: 9px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: #bbb;
      text-decoration: none;
      font-weight: 600;
      transition: color 0.25s;
    }
    .cancel-link:hover { color: #666; }

    /* ─── CORRECCIÓN QUIRÚRGICA MÓVIL ─── */
    @media (max-width: 768px) {
      .form-section { padding: 1.25rem 1rem; }
      
      .form-grid-main, .form-grid-three { 
          display: block; 
          width: 100%; 
          margin-bottom: 0; 
      }
      
      .form-group { 
          margin-bottom: 1.25rem; 
          width: 100%; 
      }
      
      input[type="text"], input[type="number"], select { 
          width: 100% !important; 
          font-size: 12px; 
          padding: 0.6rem 0.75rem; 
          min-height: 40px; 
      }

      .sizes-grid { grid-template-columns: repeat(4, 1fr); }
      .stock-inputs { grid-template-columns: repeat(2, 1fr); }
      .form-section { padding: 1.5rem; }
      .form-footer { flex-direction: column-reverse; gap: 1rem; padding: 1.5rem 1.25rem; }
      .submit-btn, .cancel-link { width: 100%; text-align: center; display: block; }
    }

    /* Image Upload Styles */
    .image-upload-zone {
      border: 2px dashed rgba(184,134,11,0.2);
      border-radius: 8px;
      transition: all 0.3s;
      background: rgba(184,134,11,0.02);
    }
    .image-upload-zone:hover {
      border-color: #B8860B;
      background: rgba(184,134,11,0.05);
    }
    .upload-placeholder {
      padding: 2rem;
      text-align: center;
      cursor: pointer;
    }
    .upload-placeholder p {
      font-size: 9px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-weight: 700;
      color: #777;
    }
    .preview-thumb {
      aspect-ratio: 1;
      border-radius: 4px;
      overflow: hidden;
      border: 1px solid rgba(0,0,0,0.1);
      position: relative;
    }
    .preview-thumb img {
      width: 100%;
      height: 100%;
      object-cover: cover;
    }
  </style>

  <!-- Back -->
  <a href="/admin/products" class="back-link">← Volver al Inventario</a>

  <!-- Header -->
  <div class="page-header">
    <p>Inventario · Nueva Pieza</p>
    <h2>Añadir al Catálogo</h2>
  </div>

  {successMessage && <div class="message success">{successMessage}</div>}
  {errorMessage && <div class="message error">{errorMessage}</div>}

  <form method="POST" class="form-card" enctype="multipart/form-data" id="productForm">
    <!-- Info Básica -->
    <div class="form-section">
      <p class="section-label">✦ Información de la Prenda</p>
      
      <div class="form-grid-main">
        <div class="form-group">
          <label for="name">Nombre de la Prenda *</label>
          <input type="text" id="name" name="name" placeholder="Ej: Camiseta de Algodón" required>
        </div>
        <div class="form-group">
          <label for="price">Precio (USD) *</label>
          <input type="number" id="price" name="price" placeholder="0.00" min="0" step="0.01" required>
        </div>
      </div>

      <div class="form-grid-three">
        <div class="form-group">
          <label for="category">Categoría Principal *</label>
          <select id="category" name="category" required>
            <option value="ropa">Ropa</option>
            <option value="accesorios">Accesorios</option>
          </select>
        </div>
        <div class="form-group">
          <label for="subcategory_id">Subcategoría</label>
          <select id="subcategory_id" name="subcategory_id">
            <option value="">Sin subcategoría</option>
            {allSubcategories?.map((s: any) => (
              <option value={s.id} data-parent={s.parent_category}>{s.name}</option>
            ))}
          </select>
        </div>
        <div class="form-group">
          <label for="collection_id">Colección / Drop</label>
          <select id="collection_id" name="collection_id">
            <option value="">Sin colección</option>
            {collections?.map((c: any) => (
              <option value={c.id}>{c.name}</option>
            ))}
          </select>
        </div>
      </div>
    </div>

    <!-- Descripción & Fotos -->
    <div class="form-section">
      <p class="section-label">◈ Contenido y Medios</p>
      <div class="form-group">
        <label for="description">Descripción de Lujo</label>
        <textarea id="description" name="description" placeholder="Una pieza que encarna la sofisticación..."></textarea>
      </div>
      <div class="form-group">
        <label for="image_files">Subir Imágenes de Lujo (Múltiple)</label>
        <div class="image-upload-zone" id="drop-zone">
            <input type="file" id="image_files" name="image_files" accept="image/*" multiple class="hidden">
            <div class="upload-placeholder" onclick="document.getElementById('image_files').click()">
                <span class="text-2xl mb-2">✦</span>
                <p>Click para seleccionar fotos</p>
                <p class="text-[7px] text-slate-400 mt-1">Recomendado: 1000x1000px, WebP o JPG (Máx. 500KB)</p>
            </div>
        </div>
        <div id="image-previews" class="grid grid-cols-4 gap-2 mt-4"></div>
      </div>
    </div>

    <!-- Stock -->
    <div class="form-section" id="sizeSelection">
      <p class="section-label">◇ Stock por Talla</p>
      <div class="sizes-grid">
        {['XS','S','M','L','XL','XXL','UNICO'].map(size => (
          <div class="size-item">
            <input type="checkbox" name="sizes[]" value={size} id={`size-${size}`}>
            <label class="size-label" for={`size-${size}`}>{size}</label>
          </div>
        ))}
      </div>
      <div class="stock-inputs" id="stockInputs">
        {['XS','S','M','L','XL','XXL','UNICO'].map(size => (
          <div class="stock-item" id={`stock-${size}`} style="display:none">
            <label>Stock {size}</label>
            <input type="number" name={`stock_${size}`} value="0" min="0" placeholder="0">
          </div>
        ))}
      </div>
    </div>

    <!-- Footer -->
    <div class="form-footer">
      <a href="/admin/products" class="cancel-link">Cancelar</a>
      <button type="submit" class="submit-btn" id="submitBtn">✦ Guardar en Catálogo</button>
    </div>
  </form>

</AdminLayout>

<script>
  document.querySelectorAll('input[name="sizes[]"]').forEach(cb => {
    cb.addEventListener('change', (e) => {
      const target = e.target as HTMLInputElement;
      const stockEl = document.getElementById(`stock-${target.value}`);
      if (stockEl) stockEl.style.display = target.checked ? 'block' : 'none';
    });
  });

  const categorySelect = document.getElementById('category') as HTMLSelectElement;
  const subcategorySelect = document.getElementById('subcategory_id') as HTMLSelectElement;
  const sizeSection = document.getElementById('sizeSelection');

  function filterSubcategories(cat: string) {
    if (!subcategorySelect) return;
    let firstVisible = '';
    subcategorySelect.querySelectorAll('option').forEach(opt => {
      const parent = opt.getAttribute('data-parent');
      if (!parent) return;
      if (parent === cat) {
        (opt as HTMLOptionElement).style.display = 'block';
        if (!firstVisible) firstVisible = opt.value;
      } else {
        (opt as HTMLOptionElement).style.display = 'none';
      }
    });
    const curr = subcategorySelect.options[subcategorySelect.selectedIndex];
    if (curr && (curr as HTMLOptionElement).style.display === 'none') subcategorySelect.value = firstVisible;
  }

  filterSubcategories(categorySelect?.value || 'ropa');

  categorySelect?.addEventListener('change', (e) => {
    const cat = (e.target as HTMLSelectElement).value;
    filterSubcategories(cat);
    
    // Manage size section based on category
    const sizes = ['XS','S','M','L','XL','XXL','UNICO'];
    if (cat === 'accesorios') {
      sizes.forEach(s => {
        const cb = document.getElementById(`size-${s}`) as HTMLInputElement;
        const cbLabel = document.querySelector(`label[for="size-${s}"]`) as HTMLElement;
        const stockEl = document.getElementById(`stock-${s}`);
        
        if (s === 'UNICO') {
          if (cb) { cb.checked = true; cb.disabled = false; }
          if (cbLabel) cbLabel.style.opacity = '1';
          if (stockEl) stockEl.style.display = 'block';
        } else {
          if (cb) { cb.checked = false; cb.disabled = true; }
          if (cbLabel) cbLabel.style.opacity = '0.3';
          if (stockEl) stockEl.style.display = 'none';
        }
      });
    } else {
      sizes.forEach(s => {
        const cb = document.getElementById(`size-${s}`) as HTMLInputElement;
        const cbLabel = document.querySelector(`label[for="size-${s}"]`) as HTMLElement;
        if (cb) cb.disabled = false;
        if (cbLabel) cbLabel.style.opacity = '1';
      });
    }
  });

  // Image Preview Logic
  const imageInput = document.getElementById('image_files') as HTMLInputElement;
  const previewContainer = document.getElementById('image-previews');

  imageInput?.addEventListener('change', () => {
    if (!previewContainer) return;
    previewContainer.innerHTML = '';
    
    if (imageInput.files) {
      Array.from(imageInput.files).forEach(file => {
        const reader = new FileReader();
        reader.onload = (e) => {
          const div = document.createElement('div');
          div.className = 'preview-thumb';
          div.innerHTML = `<img src="${e.target?.result}" alt="Preview">`;
          previewContainer.appendChild(div);
        };
        reader.readAsDataURL(file);
      });
    }
  });

  // Double-submit protection
  const form = document.getElementById('productForm') as HTMLFormElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

  form?.addEventListener('submit', () => {
    submitBtn.disabled = true;
    submitBtn.innerHTML = '✦ GUARDANDO...';
    submitBtn.style.opacity = '0.5';
  });
</script>
