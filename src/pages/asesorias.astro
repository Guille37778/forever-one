---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Forever One | Personal Shopper & Asesoría">
    <Header />
    <main>
        <!-- Hero Uniforme -->
        <Hero 
            title="Personal"
            highlight="Shopper"
            subtitle="tu puerta al mundo"
            tagline="Experiencia VIP de Compra"
            image="https://images.unsplash.com/photo-1483985988355-763728e1935b?q=80&w=2000"
            buttonText="Iniciar Asesoría"
            buttonLink="https://wa.me/584244557693"
        />

        <!-- Intro Section -->
        <section class="py-24 bg-white overflow-hidden w-full">
            <div class="max-w-7xl mx-auto px-6">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
                    <div data-aos="fade-right">
                        <span class="text-gold font-bold tracking-[0.5em] uppercase text-[10px] mb-4 block">Servicio Concierge</span>
                        <h2 class="text-4xl md:text-6xl font-serif text-[#1A1A1A] font-black italic mb-8 leading-tight pr-4">
                            Tus Deseos Globales, <br> <span class="metal-gold-text">Nuestra Gestión</span>
                        </h2>
                        <p class="text-slate-500 text-sm md:text-lg font-light italic leading-relaxed mb-10 pr-2">
                            Olvídese de las complicaciones de las aduanas, los pagos internacionales y la incertidumbre de los proveedores. En **Forever One**, transformamos su experiencia en Amazon, Alibaba y Shein en un proceso de lujo sin fricciones.
                        </p>
                        <div class="flex flex-col gap-6">
                            <div class="flex items-start gap-4">
                                <div class="w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center text-gold shrink-0">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <p class="text-sm font-bold text-black uppercase tracking-widest pt-2">Cero Riesgos en Aduanas</p>
                            </div>
                            <div class="flex items-start gap-4">
                                <div class="w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center text-gold shrink-0">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <p class="text-sm font-bold text-black uppercase tracking-widest pt-2">Proveedores Verificados</p>
                            </div>
                        </div>
                    </div>
                    <div class="relative" data-aos="fade-left">
                        <div class="aspect-[4/5] overflow-hidden border border-gold/20 shadow-2xl">
                            <img src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?q=80&w=1000" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-1000">
                        </div>
                        <div class="absolute -bottom-10 -left-10 bg-black p-8 border border-gold/30 hidden md:block">
                            <p class="text-gold font-serif text-4xl italic font-black">100%</p>
                            <p class="text-white text-[8px] uppercase tracking-[0.4em] mt-2">Seguridad Garantizada</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Protocolo/Pasos -->
        <section class="py-32 bg-[#F9F8F6] border-y border-gold/10 overflow-hidden w-full">
            <div class="max-w-7xl mx-auto px-6">
                <div class="text-center mb-24" data-aos="fade-up">
                    <h3 class="text-gold font-bold tracking-[0.6em] uppercase text-[11px] mb-4">El Protocolo FO1</h3>
                    <h4 class="text-4xl md:text-7xl font-serif text-[#1A1A1A] font-black italic pr-12">Pasos de la <span class="metal-gold-text">Asesoría</span></h4>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                    <!-- Paso 1 -->
                    <div class="bg-white p-10 border border-gold/10 hover:border-gold transition-all duration-500 group" data-aos="fade-up">
                        <span class="text-5xl font-serif font-black text-gold/10 group-hover:text-gold/20 transition-colors mb-6 block">01</span>
                        <h5 class="text-xl font-serif font-black italic text-[#1A1A1A] mb-4 pr-2">Consulta Inicial</h5>
                        <p class="text-slate-500 text-sm font-light italic leading-relaxed">Nos contactas vía WhatsApp para definir tus necesidades, presupuesto y estilos deseados.</p>
                    </div>

                    <!-- Paso 2 -->
                    <div class="bg-white p-10 border border-gold/10 hover:border-gold transition-all duration-500 group" data-aos="fade-up" data-aos-delay="100">
                        <span class="text-5xl font-serif font-black text-gold/10 group-hover:text-gold/20 transition-colors mb-6 block">02</span>
                        <h5 class="text-xl font-serif font-black italic text-[#1A1A1A] mb-4 pr-2">Curaduría Digital</h5>
                        <p class="text-slate-500 text-sm font-light italic leading-relaxed">Nuestra experta selecciona las mejores opciones en Amazon, Shein o Alibaba, auditando la reputación de los vendedores.</p>
                    </div>

                    <!-- Paso 3 -->
                    <div class="bg-white p-10 border border-gold/10 hover:border-gold transition-all duration-500 group" data-aos="fade-up" data-aos-delay="200">
                        <span class="text-5xl font-serif font-black text-gold/10 group-hover:text-gold/20 transition-colors mb-6 block">03</span>
                        <h5 class="text-xl font-serif font-black italic text-[#1A1A1A] mb-4 pr-2">Gestión y Logística</h5>
                        <p class="text-slate-500 text-sm font-light italic leading-relaxed">Realizamos los pagos y gestionamos toda la documentación aduanal necesaria para el ingreso al país.</p>
                    </div>

                    <!-- Paso 4 -->
                    <div class="bg-white p-10 border border-gold/10 hover:border-gold transition-all duration-500 group" data-aos="fade-up" data-aos-delay="300">
                        <span class="text-5xl font-serif font-black text-gold/10 group-hover:text-gold/20 transition-colors mb-6 block">04</span>
                        <h5 class="text-xl font-serif font-black italic text-[#1A1A1A] mb-4 pr-2">Entrega Directa</h5>
                        <p class="text-slate-500 text-sm font-light italic leading-relaxed">Recibes tu mercancía en la puerta de tu casa o agencia de preferencia con garantía total de satisfacción.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Seguridad Section -->
        <section class="py-32 bg-white overflow-hidden w-full">
            <div class="max-w-7xl mx-auto px-6">
                <div class="bg-black p-12 md:p-24 relative overflow-hidden" data-aos="zoom-in">
                    <div class="absolute top-0 right-0 w-1/3 h-full bg-gold/5 -skew-x-12 translate-x-1/2"></div>
                    
                    <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                        <div>
                            <h3 class="text-gold font-bold tracking-[0.5em] uppercase text-[11px] mb-6">Seguridad y Confianza</h3>
                            <h4 class="text-4xl md:text-6xl font-serif text-white font-black italic mb-10 leading-tight pr-12">
                                ¿Por qué comprar con <br> <span class="metal-gold-text">nosotros?</span>
                            </h4>
                            <div class="space-y-8">
                                <div class="flex gap-6 border-b border-white/10 pb-6">
                                    <div class="text-gold font-serif text-3xl italic font-black">A.</div>
                                    <div>
                                        <p class="text-white font-bold text-xs uppercase tracking-widest mb-2">Auditoría Técnica de Proveedores</p>
                                        <p class="text-slate-400 text-sm italic font-light pr-4">Eliminamos las estafas verificando la trayectoria legal y comercial de cada vendedor internacional.</p>
                                    </div>
                                </div>
                                <div class="flex gap-6 border-b border-white/10 pb-6">
                                    <div class="text-gold font-serif text-3xl italic font-black">B.</div>
                                    <div>
                                        <p class="text-white font-bold text-xs uppercase tracking-widest mb-2">Control de Calidad Textil</p>
                                        <p class="text-slate-400 text-sm italic font-light pr-4">Aseguramos que los materiales y cortes coincidan con lo prometido en las plataformas digitales.</p>
                                    </div>
                                </div>
                                <div class="flex gap-6">
                                    <div class="text-gold font-serif text-3xl italic font-black">C.</div>
                                    <div>
                                        <p class="text-white font-bold text-xs uppercase tracking-widest mb-2">Blindaje Aduanal</p>
                                        <p class="text-slate-400 text-sm italic font-light pr-4">Contamos con expertos que agilizan los trámites legales, evitando retenciones y sobrecostos inesperados.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="hidden lg:block">
                            <img src="https://images.unsplash.com/photo-1483985988355-763728e1935b?q=80&w=1000" class="w-full h-[600px] object-cover opacity-60 border border-gold/30">
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA Final -->
        <section class="py-24 bg-[#F9F8F6] border-t border-gold/10 overflow-hidden w-full">
            <div class="max-w-4xl mx-auto px-6 text-center" data-aos="fade-up">
                <h3 class="text-2xl md:text-5xl font-serif text-[#1A1A1A] font-black italic mb-10 leading-tight pr-12">Inicie hoy su experiencia de <br> <span class="metal-gold-text pr-12">Shopper Personal</span></h3>
                <p class="text-slate-500 text-sm md:text-xl font-light italic mb-12 pr-2">Hable directamente con nuestra experta, Nazareth, para una atención personalizada.</p>
                <div class="flex justify-center">
                    <a href="https://wa.me/584244557693" target="_blank" class="btn-metal-gold px-12 py-6 text-[10px] uppercase tracking-[0.5em] font-black text-white shadow-2xl hover:scale-105 transition-all duration-700">
                        SÍ, QUIERO MI ASESORÍA VIP
                    </a>
                </div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>

<style>
    .btn-metal-gold {
        background: linear-gradient(135deg, #8B6508 0%, #B8860B 25%, #f3cf7a 50%, #B8860B 75%, #8B6508 100%);
        background-size: 200% auto;
        animation: shineBtn 5s linear infinite;
    }
    @keyframes shineBtn { to { background-position: 200% center; } }
</style>
