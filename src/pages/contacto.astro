---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';
---

<Layout title="Forever One | Contacto Exclusivo">
    <Header />
    
    <main class="overflow-hidden bg-white">
        <!-- Hero: The Sanctuary of Connection -->
        <Hero 
            title="Líneas de"
            highlight="Exclusividad"
            subtitle="atención personalizada de alta gama"
            tagline="Forever One Experience"
            image="https://images.unsplash.com/photo-1512436991641-6745cdb1723f?q=80&w=2000"
            showButton={false}
        />

        <!-- Section: The Concierge (Direct Channels) - MINIMALIST LIGHT -->
        <section class="relative py-32 bg-white border-b border-black/5 overflow-hidden">
            <div class="max-w-7xl mx-auto px-6 relative z-10">
                <div class="text-center mb-24">
                    <span class="text-gold text-[9px] uppercase tracking-[0.6em] font-black mb-6 border-b border-gold/30 pb-2 inline-block" data-aos="fade-up">Atención Directa</span>
                    <h2 class="text-5xl md:text-7xl font-serif text-black font-black italic tracking-tighter leading-none" data-aos="fade-up" data-aos-delay="100">
                        Canales de <br> <span class="metal-gold-text">Conserjería</span>
                    </h2>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
                    <!-- WhatsApp -->
                    <a href="https://wa.me/584244557693" target="_blank" 
                       class="group p-12 bg-[#F2F1EE] rounded-sm text-center transition-all duration-700 hover:-translate-y-3 hover:shadow-2xl hover:bg-white">
                        <div class="mb-10 flex justify-center">
                            <div class="w-20 h-20 border border-gold/30 rounded-full flex items-center justify-center p-5 transition-all duration-700 group-hover:border-gold group-hover:bg-gold/5 group-hover:shadow-[0_0_30px_rgba(184,134,11,0.2)]">
                                <svg class="w-full h-full text-gold" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.148-.67-1.614-.918-2.213-.242-.588-.487-.51-.67-.51-.172-.001-.371-.001-.57-.001-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                                </svg>
                            </div>
                        </div>
                        <h4 class="text-black text-xl font-serif font-black italic tracking-wide mb-3">WhatsApp VIP</h4>
                        <p class="text-slate-500 text-[9px] uppercase tracking-[0.4em] font-black">Solicitar Asistencia</p>
                    </a>
                    
                    <!-- Instagram -->
                    <a href="https://www.instagram.com/foreveronefashion" target="_blank" 
                       class="group p-12 bg-[#F2F1EE] rounded-sm text-center transition-all duration-700 hover:-translate-y-3 hover:shadow-2xl hover:bg-white">
                        <div class="mb-10 flex justify-center">
                            <div class="w-20 h-20 border border-gold/30 rounded-full flex items-center justify-center p-5 transition-all duration-700 group-hover:border-gold group-hover:bg-gold/5 group-hover:shadow-[0_0_30px_rgba(184,134,11,0.2)]">
                                <svg class="w-full h-full text-gold" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.334 3.608 1.308.975.975 1.247 2.242 1.308 3.608.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.062 1.366-.334 2.633-1.308 3.608-.975.975-2.242 1.247-3.608 1.308-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.062-2.633-.334-3.608-1.308-.975-.975-1.247-2.242-1.308-3.608-.058-1.266-.07-1.646-.07-4.85s.012-3.584.07-4.85c.062-1.366.334-2.633 1.308-3.608.975-.975 2.242-1.247 3.608-1.308 1.266-.058 1.646-.07 4.85-.07zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.355 2.618 6.778 6.98 6.977 1.28.057 1.688.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                                </svg>
                            </div>
                        </div>
                        <h4 class="text-black text-xl font-serif font-black italic tracking-wide mb-3">Instagram</h4>
                        <p class="text-slate-500 text-[9px] uppercase tracking-[0.4em] font-black">@foreveronefashion</p>
                    </a>

                    <!-- TikTok -->
                    <a href="https://www.tiktok.com/@foreveronefashion" target="_blank" 
                       class="group p-12 bg-[#F2F1EE] rounded-sm text-center transition-all duration-700 hover:-translate-y-3 hover:shadow-2xl hover:bg-white">
                        <div class="mb-10 flex justify-center">
                            <div class="w-20 h-20 border border-gold/30 rounded-full flex items-center justify-center p-5 transition-all duration-700 group-hover:border-gold group-hover:bg-gold/5 group-hover:shadow-[0_0_30px_rgba(184,134,11,0.2)]">
                                <svg class="w-full h-full text-gold" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.17-2.86-.6-4.12-1.31a8.386 8.386 0 01-1.87-1.39v9.23c0 2.1-.35 4.26-1.74 5.82-1.5 1.75-3.9 2.35-6.13 2.1-2.45-.21-4.74-1.63-5.83-3.83-1.46-3.05-.28-7.23 2.84-8.82.93-.45 1.95-.69 2.99-.71v4.03c-1.44.02-2.91.73-3.56 2.05-.62 1.35-.3 3.12.83 4.12.91.86 2.45.96 3.44.19.82-.6.94-1.76.94-2.73V0z"/>
                                </svg>
                            </div>
                        </div>
                        <h4 class="text-black text-xl font-serif font-black italic tracking-wide mb-3">TikTok</h4>
                        <p class="text-slate-500 text-[9px] uppercase tracking-[0.4em] font-black">Inspiración Diaria</p>
                    </a>
                </div>
            </div>
        </section>

        <!-- Section: Store Location Side-by-Side -->
        <section class="py-32 bg-white relative">
            <div class="max-w-7xl mx-auto px-6">
                <div class="flex flex-col lg:flex-row gap-16 lg:gap-24 items-center">
                    <div class="w-full lg:w-[40%]" data-aos="fade-right">
                        <span class="text-gold text-[9px] uppercase tracking-[0.5em] font-black mb-6 block">Tienda Física</span>
                        <h3 class="text-4xl md:text-6xl font-serif text-[#1A1A1A] font-black italic tracking-tighter leading-[1.1] mb-12">
                            Ubicación de nuestra <br> <span class="metal-gold-text">tienda</span>
                        </h3>
                        <div class="space-y-8">
                            <div class="flex items-start gap-6 border-l-2 border-gold pl-8 py-3 bg-[#FAF9F6] rounded-r-lg">
                                <div>
                                    <span class="text-gold text-[8px] uppercase tracking-[0.4em] font-bold block mb-2">Dirección Atelier</span>
                                    <p class="text-black text-xl font-serif italic font-black leading-tight mb-2">Güigüe, Carabobo, Venezuela.</p>
                                    <p class="text-slate-500 text-xs font-medium tracking-wide">Yuma, Sector La Ensenada, Casa N# XXXXXX</p>
                                </div>
                            </div>
                            <div class="flex items-start gap-6 border-l-2 border-black/5 pl-8 py-3">
                                <div>
                                    <span class="text-slate-400 text-[8px] uppercase tracking-[0.4em] font-bold block mb-2">Horario de Atención</span>
                                    <p class="text-black text-sm font-serif italic font-bold">Lunes a Sábado: 9:00 AM — 6:00 PM</p>
                                    <p class="text-slate-400 text-[9px] mt-2 font-bold italic tracking-wider">Planifique su visita bajo cita previa</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="w-full lg:w-[60%] h-[500px] md:h-[650px] relative shadow-2xl rounded-sm overflow-hidden" data-aos="zoom-in" data-aos-delay="200">
                        <iframe 
                            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15701.3734008779!2d-67.7951566!3d10.1517548!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e8061e88941031f%3A0xc6646b9a951c0709!2sGuigue%2C%20Carabobo!5e0!3m2!1ses-419!2sve!4v1710150000000!5m2!1ses-419!2sve" 
                            class="w-full h-full border-0 grayscale opacity-90 hover:grayscale-0 transition-all duration-1000"
                            allowfullscreen="" 
                            loading="lazy">
                        </iframe>
                        <div class="absolute inset-0 pointer-events-none border-[1px] border-black/5"></div>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>
