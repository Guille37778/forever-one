---
const base = import.meta.env.BASE_URL;
---

<nav :class="{ 'py-4 glass-nav border-b border-gold/20': !atTop || mobileMenuOpen, 'py-8 bg-transparent': atTop && !mobileMenuOpen }"
     class="fixed top-0 w-full z-[1000] transition-all duration-500">
    
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between">
        
        <a href={`${base}`} class="group relative z-[1100] flex items-center gap-4">
            <img src={`${base}/faviconf.png`} 
                 class="h-10 md:h-12 w-auto object-contain transition-all duration-500 group-hover:scale-110" 
                 style="filter: drop-shadow(0 0 1px #B8860B) drop-shadow(0 0 10px rgba(212,175,55,0.6)) drop-shadow(0 0 2px rgba(255,255,255,0.2));"
                 alt="Forever One Shield">
            <span class="text-xl md:text-3xl font-serif font-black italic tracking-tighter text-white pr-4">
                Forever <span class="metal-gold-text inline-block -ml-0.5 md:-ml-2 pr-6">One</span>
            </span>
        </a>

        <div class="hidden lg:flex items-center gap-8">
            <a href={`${base}`} class="nav-link">Inicio</a>
            <a href={`${base}/catalogos`} class="nav-link">Catálogos</a>
            <a href={`${base}/asesorias`} class="nav-link">Asesorías</a>
            <a href={`${base}/ropas`} class="nav-link">Ropa</a>
            <a href={`${base}/contacto`} 
               class="ml-4 px-6 py-2 border border-gold/40 text-gold text-[9px] uppercase tracking-[0.4em] font-black hover:bg-gold hover:text-black transition-all duration-500">
                Contacto
            </a>
        </div>

        <button @click="mobileMenuOpen = !mobileMenuOpen" 
                class="lg:hidden relative z-[1100] p-2 outline-none focus:outline-none"
                aria-label="Menú">
            <div class="w-6 space-y-1.5">
                <span :class="mobileMenuOpen ? 'bg-gold rotate-45 translate-y-2' : (atTop ? 'bg-white' : 'bg-gold')" 
                      class="block h-0.5 w-full transition-all duration-300 origin-center"></span>
                
                <span :class="mobileMenuOpen ? 'opacity-0' : (atTop ? 'bg-white' : 'bg-gold')" 
                      class="block h-0.5 w-full transition-all duration-300"></span>
                
                <span :class="mobileMenuOpen ? 'bg-gold -rotate-45 -translate-y-2' : (atTop ? 'bg-white' : 'bg-gold')" 
                      class="block h-0.5 w-full transition-all duration-300 origin-center"></span>
            </div>
        </button>
    </div>
</nav>

<div x-show="mobileMenuOpen" 
     x-transition:enter="transition ease-out duration-400"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100"
     x-transition:leave="transition ease-in duration-300"
     x-transition:leave-start="opacity-100"
     x-transition:leave-end="opacity-0"
     x-cloak
     class="fixed inset-0 bg-black z-[900] flex flex-col justify-center items-center">
    
    <div class="flex flex-col gap-8 text-center px-6">
        <a @click="mobileMenuOpen = false" href={`${base}`} 
           class="text-[11px] uppercase tracking-[0.6em] text-white/90 hover:text-gold transition-colors font-bold">Inicio</a>
        
        <a @click="mobileMenuOpen = false" href={`${base}/catalogos`} 
           class="text-[11px] uppercase tracking-[0.6em] text-white/90 font-bold">Catálogo</a>
        
        <a @click="mobileMenuOpen = false" href={`${base}/asesorias`} 
           class="text-[11px] uppercase tracking-[0.6em] text-white/90 hover:text-gold transition-colors font-bold">Asesoría</a>
        
        <a @click="mobileMenuOpen = false" href={`${base}/ropas`} 
           class="text-[11px] uppercase tracking-[0.6em] text-white/90 hover:text-gold transition-colors font-bold">Ropa</a>
        
        <div class="mt-4">
            <a @click="mobileMenuOpen = false" href={`${base}/contacto`} 
               class="inline-block px-10 py-4 border border-gold/50 text-gold text-[9px] uppercase tracking-[0.4em] font-black hover:bg-gold hover:text-black transition-all">
                Contacto
            </a>
        </div>
    </div>

    <div class="absolute bottom-10 left-0 w-full text-center opacity-5 pointer-events-none">
        <span class="text-[7rem] font-serif font-black text-gold italic">FO1</span>
    </div>
</div>
