---
import { supabase } from '../lib/supabase';
const baseEnv = import.meta.env.BASE_URL || '/';
const base = baseEnv.replace(/\/$/, '');
const homeUrl = base || '/';

// Cargar subcategorías para el menú dinámico con timeout de seguridad
let subcategories: any[] = [];
try {
    const queryPromise = supabase
        .from('subcategories')
        .select('*')
        .order('name', { ascending: true });
    
    // Timeout de 1.5 segundos para no bloquear el renderizado
    const timeoutPromise = new Promise((_, reject) => 
        setTimeout(() => reject(new Error('Timeout en Supabase')), 1500)
    );

    const { data, error } = await Promise.race([queryPromise, timeoutPromise]) as any;
    
    if (!error && data) {
        subcategories = data;
    }
} catch (e) {
    console.error('Error en Header (Supabase):', e);
}

const ropaSub = Array.isArray(subcategories) ? subcategories.filter(s => s.parent_category === 'ropa') : [];
const accesoriosSub = Array.isArray(subcategories) ? subcategories.filter(s => s.parent_category === 'accesorios') : [];
const { isBlack = false } = Astro.props;
---

<nav :class={isBlack ? "'py-4 glass-nav border-b border-gold/20'" : "{ 'py-4 glass-nav border-b border-gold/20': !atTop || mobileMenuOpen, 'py-8 bg-transparent': atTop && !mobileMenuOpen }"}
     class="fixed top-0 w-full z-[1000] transition-all duration-500">
    
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between">
        
        <a href={homeUrl} class="group relative z-[1100] flex items-center gap-4">
            <!-- Dynamic Logo Container using CSS Mask - Permanently Gold -->
            <div class="metal-gold-bg shadow-[0_0_20px_rgba(184,134,11,0.3)] h-10 md:h-14 w-10 md:w-14 transition-all duration-500 group-hover:scale-110"
                 style={`-webkit-mask-image: url(${base}/logo_circular.png); -webkit-mask-size: contain; -webkit-mask-repeat: no-repeat; -webkit-mask-position: center; mask-image: url(${base}/logo_circular.png); mask-size: contain; mask-repeat: no-repeat; mask-position: center;`}
                 aria-label="Forever One Logo">
            </div>
            <span class="text-xl md:text-3xl font-serif font-black italic tracking-tighter text-white pr-4">
                Forever <span class="metal-gold-text inline-block -ml-0.5 md:-ml-2 pr-6">One</span>
            </span>
        </a>

        <div class="hidden lg:flex items-center gap-8">
            <a href={homeUrl} class="nav-link">Inicio</a>
            <a href={`${base}/catalogos`} class="nav-link">Catálogos</a>
            
            <!-- Dropdown Prendas -->
            <div class="relative group" x-data="{ open: false }" @click.away="open = false">
                <button @click="open = !open" 
                        class="nav-link flex items-center gap-1 outline-none group">
                    Prendas
                    <svg :class="open ? 'rotate-180' : ''" class="w-3 h-3 transition-transform duration-300 text-gold/60 group-hover:text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                </button>
                
                <!-- Dropdown Menu -->
                <div x-show="open" 
                     x-transition:enter="transition ease-out duration-200"
                     x-transition:enter-start="opacity-0 translate-y-2"
                     x-transition:enter-end="opacity-100 translate-y-0"
                     x-cloak
                     class="absolute top-full left-1/2 -translate-x-1/2 mt-4 w-[400px] bg-black/95 backdrop-blur-xl border border-gold/20 p-6 shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
                    
                    <div class="grid grid-cols-2 gap-8">
                        <!-- Column 1: Ropa -->
                        <div>
                            <p class="text-[10px] uppercase tracking-[0.3em] text-gold font-bold mb-4 border-b border-gold/10 pb-2">Ropa</p>
                            <div class="space-y-3">
                                <a href={`${base}/ropas?cat=ropa`} class="block text-[11px] text-white/70 hover:text-gold transition-colors uppercase tracking-wider">Ver Todo</a>
                                {ropaSub.map(sub => (
                                    <a href={`${base}/ropas?sub=${sub.slug}`} class="block text-[11px] text-white/50 hover:text-gold transition-colors uppercase tracking-wider italic">
                                        {sub.name}
                                    </a>
                                ))}
                            </div>
                        </div>
                        
                        <!-- Column 2: Accesorios -->
                        <div>
                            <p class="text-[10px] uppercase tracking-[0.3em] text-gold font-bold mb-4 border-b border-gold/10 pb-2">Accesorios</p>
                            <div class="space-y-3">
                                <a href={`${base}/ropas?cat=accesorios`} class="block text-[11px] text-white/70 hover:text-gold transition-colors uppercase tracking-wider">Ver Todo</a>
                                {accesoriosSub.map(sub => (
                                    <a href={`${base}/ropas?sub=${sub.slug}`} class="block text-[11px] text-white/50 hover:text-gold transition-colors uppercase tracking-wider italic">
                                        {sub.name}
                                    </a>
                                ))}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <a href={`${base}/contacto`} class="nav-link">Contacto</a>

            <!-- Auth/Profile Section (Desktop) -->
            <div class="ml-4" x-data="{ open: false }" @click.away="open = false" x-cloak>
                <!-- Guest State -->
                <button x-show="!$store.auth?.isLoggedIn" 
                        @click="$store.auth.toggleModal(true)"
                        class="px-6 py-2 border border-gold/40 text-gold text-[9px] uppercase tracking-[0.2em] font-medium hover:bg-gold hover:text-black transition-all duration-500">
                    Ingresar
                </button>

                <!-- Logged In State -->
                <div x-show="$store.auth?.isLoggedIn" class="relative">
                    <button @click="open = !open" 
                            class="flex items-center gap-3 group outline-none">
                        <div class="flex flex-col items-end">
                            <div class="flex items-center gap-1.5 group-hover:text-gold transition-colors">
                                <span class="text-[7px] text-gold/60 font-black uppercase tracking-[0.2em]">Bienvenido,</span>
                                <span class="text-[9px] text-white/90 font-black uppercase tracking-widest" 
                                      x-text="($store.auth.profile?.full_name || $store.auth.user?.email || 'Cliente').split(' ')[0]"></span>
                            </div>
                            <span class="text-[7px] text-gold/40 font-bold uppercase tracking-[0.1em]">Cliente Forever One</span>
                        </div>
                        <div class="w-8 h-8 rounded-full border border-gold/30 flex items-center justify-center bg-gold/10 text-gold group-hover:bg-gold group-hover:text-black transition-all">
                            <span class="text-[10px] font-black" x-text="($store.auth.profile?.full_name || 'C')?.charAt(0)"></span>
                        </div>
                    </button>

                    <!-- Profile Dropdown -->
                    <div x-show="open" 
                         x-transition:enter="transition ease-out duration-200"
                         x-transition:enter-start="opacity-0 translate-y-2"
                         x-transition:enter-end="opacity-100 translate-y-0"
                         x-cloak
                         class="absolute top-full right-0 mt-4 w-56 bg-black/95 backdrop-blur-xl border border-gold/20 p-2 shadow-2xl">
                        <div class="px-4 py-3 border-b border-gold/10 mb-2">
                             <p class="text-[8px] text-gold/60 uppercase tracking-widest mb-1">Bienvenido,</p>
                             <p class="text-[10px] text-white font-black uppercase truncate" 
                                x-text="$store.auth.profile?.full_name || $store.auth.user?.email || ''"></p>
                        </div>
                        <a href={`${base}/perfil`} class="flex items-center gap-3 px-4 py-3 text-[9px] text-white/70 hover:text-gold hover:bg-white/5 transition-all uppercase tracking-widest">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                            Mi Perfil y Pedidos
                        </a>
                        <button @click="$store.auth.logout()" class="w-full flex items-center gap-3 px-4 py-3 text-[9px] text-red-400 hover:text-red-300 hover:bg-white/5 transition-all uppercase tracking-widest">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                            Cerrar Sesión
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <button @click="mobileMenuOpen = !mobileMenuOpen" 
                class="lg:hidden relative z-[1100] p-2 outline-none focus:outline-none"
                aria-label="Menú">
            <div class="w-6 space-y-1.5">
                <span :class="mobileMenuOpen ? 'bg-gold rotate-45 translate-y-2' : (atTop ? 'bg-white' : 'bg-gold')" 
                      class="block h-0.5 w-full transition-all duration-300 origin-center"></span>
                
                <span :class="mobileMenuOpen ? 'opacity-0' : (atTop ? 'bg-white' : 'bg-gold')" 
                      class="block h-0.5 w-full transition-all duration-300"></span>
                
                <span :class="mobileMenuOpen ? 'bg-gold -rotate-45 -translate-y-2' : (atTop ? 'bg-white' : 'bg-gold')" 
                      class="block h-0.5 w-full transition-all duration-300 origin-center"></span>
            </div>
        </button>
    </div>
</nav>

<div x-show="mobileMenuOpen" 
     x-transition:enter="transition ease-out duration-400"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100"
     x-transition:leave="transition ease-in duration-300"
     x-transition:leave-start="opacity-100"
     x-transition:leave-end="opacity-0"
     x-cloak
     class="fixed inset-0 bg-black z-[900] overflow-y-auto py-20 flex flex-col items-center">
    
    <div class="flex flex-col gap-8 text-center px-6">
        <a @click="mobileMenuOpen = false" href={homeUrl} 
           class="text-[11px] uppercase tracking-[0.3em] text-white/90 hover:text-gold transition-colors font-medium">Inicio</a>
        
        <a @click="mobileMenuOpen = false" href={`${base}/catalogos`} 
           class="text-[11px] uppercase tracking-[0.3em] text-white/90 hover:text-gold transition-colors font-medium">Catálogos</a>
        
        <div x-data="{ expanded: false }">
            <button @click="expanded = !expanded" 
                    class="w-full text-[11px] uppercase tracking-[0.3em] text-white/90 hover:text-gold transition-colors font-medium flex items-center justify-center gap-2">
                Prendas
                <svg :class="expanded ? 'rotate-180' : ''" class="w-3 h-3 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
            </button>
            <div x-show="expanded" x-collapse x-cloak class="mt-4 space-y-4 bg-white/5 p-5 text-left border-t border-white/5">
                <a @click="mobileMenuOpen = false" href={`${base}/ropas`} class="block text-[9px] text-gold hover:text-gold/80 uppercase tracking-[0.3em] font-bold mb-2">Ver Todo</a>
                
                <!-- Ropa Section -->
                <div class="space-y-2 pt-2">
                    <p class="text-[8px] text-white/30 uppercase tracking-[0.4em] font-bold border-b border-white/10 pb-1">Ropa</p>
                    {ropaSub.map(sub => (
                        <a @click="mobileMenuOpen = false" href={`${base}/ropas?sub=${sub.slug}`} class="block text-[10px] text-white/70 hover:text-gold uppercase tracking-widest italic py-1">
                            {sub.name}
                        </a>
                    ))}
                </div>

                <!-- Accesorios Section -->
                <div class="space-y-2 pt-2">
                    <p class="text-[8px] text-white/30 uppercase tracking-[0.4em] font-bold border-b border-white/10 pb-1">Accesorios</p>
                    {accesoriosSub.map(sub => (
                        <a @click="mobileMenuOpen = false" href={`${base}/ropas?sub=${sub.slug}`} class="block text-[10px] text-white/70 hover:text-gold uppercase tracking-widest italic py-1">
                            {sub.name}
                        </a>
                    ))}
                </div>
            </div>
        </div>
        
        <div class="mt-4 flex flex-col items-center gap-6" x-cloak>
            <!-- Mobile Auth Section -->
            <div x-show="!$store.auth?.isLoggedIn" class="w-full text-center">
                <button @click="mobileMenuOpen = false; $store.auth.toggleModal(true)" 
                        class="w-full px-10 py-5 bg-gold text-black text-[10px] font-black uppercase tracking-[0.3em] active:scale-95 transition-all">
                    Iniciar Sesión
                </button>
            </div>

            <div x-show="$store.auth?.isLoggedIn" class="w-full flex flex-col items-center gap-4 py-8 border-y border-gold/10">
                <div class="flex flex-col items-center gap-1 mb-2">
                    <span class="text-[8px] text-gold/60 uppercase tracking-[0.4em] font-black">Bienvenido a Forever One</span>
                    <p class="text-white text-sm font-black uppercase tracking-[0.2em]" 
                       x-text="$store.auth?.profile?.full_name || $store.auth?.user?.email || ''"></p>
                </div>
                <div class="w-20 h-20 rounded-full border-2 border-gold flex items-center justify-center text-gold text-2xl font-black shadow-2xl bg-gold/5">
                    <span x-text="($store.auth?.profile?.full_name || $store.auth?.user?.email || 'C')?.charAt(0)?.toUpperCase()"></span>
                </div>
                <a @click="mobileMenuOpen = false" href="/perfil" class="text-gold text-[9px] uppercase tracking-[0.4em] font-black border border-gold/30 px-6 py-2 hover:bg-gold hover:text-black transition-all">Mi Perfil</a>
                <button @click="$store.auth.logout()" class="text-red-400 text-[9px] uppercase tracking-[0.4em] font-black mt-2 hover:text-red-300 transition-colors">Cerrar Sesión</button>
            </div>

            <a @click="mobileMenuOpen = false" href={`${base}/contacto`} 
               class="inline-block px-10 py-4 border border-gold/50 text-gold text-[9px] uppercase tracking-[0.2em] font-medium hover:bg-gold hover:text-black transition-all">
                Contacto
            </a>
        </div>
    </div>

    <div class="absolute bottom-10 left-0 w-full text-center opacity-5 pointer-events-none">
        <span class="text-[7rem] font-serif font-black text-gold italic">FO1</span>
    </div>
</div>
