---
interface Props {
    title?: string;
    highlight?: string;
    subtitle?: string;
    tagline?: string;
    image?: string;
    showButton?: boolean;
    buttonText?: string;
    buttonLink?: string;
}

const { 
    title = "Forever", 
    highlight = "One", 
    subtitle = "siempre único", 
    tagline = "Casa de Moda de Alto Nivel",
    image = "https://images.unsplash.com/photo-1490481651871-ab68de25d43d?auto=format&fit=crop&q=80&w=2000",
    showButton = true,
    buttonText = "Ver Productos",
    buttonLink = "/ropas"
} = Astro.props;

const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;
const cleanLink = buttonLink.startsWith('/') ? buttonLink : `/${buttonLink}`;
const fullButtonLink = buttonLink.startsWith('http') ? buttonLink : `${cleanBase}${cleanLink}`;
---

<section class="relative min-h-[90vh] md:min-h-screen flex items-center justify-center bg-black overflow-hidden">
    <div class="absolute inset-0 z-0">
        <img src={image} 
             alt="Luxury Fashion Hero" 
             class="w-full h-full object-cover opacity-50 animate-heroZoom">
        <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black"></div>
    </div>

    <div class="container mx-auto px-6 py-20 relative z-10 text-center">
        <div class="mb-6 opacity-0 animate-heroUp" style="animation-delay: 0.2s; animation-fill-mode: forwards;">
            <span class="text-gold font-bold tracking-[0.5em] uppercase text-[9px] md:text-[11px] border-b border-gold/30 pb-2">{tagline}</span>
        </div>
        <h1 id="hero-title" class="text-5xl md:text-9xl font-serif font-black tracking-tighter mb-4 italic leading-tight opacity-0 animate-heroUp" 
            style="animation-delay: 0.5s; animation-fill-mode: forwards;">
            {title} <span id="hero-highlight" class="metal-gold-text inline-block -ml-2 md:-ml-4 pr-12">{highlight}</span>
        </h1>
        <h2 class="text-lg md:text-3xl font-light tracking-[0.3em] text-gray-400 uppercase italic mb-12 opacity-0 animate-heroUp pr-8" 
            style="animation-delay: 0.8s; animation-fill-mode: forwards;">
            <span class="text-white">{subtitle.split(' ')[0]}</span> {subtitle.split(' ').slice(1).join(' ')}
        </h2>
        
        {showButton && (
            <div class="opacity-0 animate-heroUp" style="animation-delay: 1.1s; animation-fill-mode: forwards;">
                <a href={fullButtonLink} class="inline-block px-12 py-5 bg-gold text-white font-black uppercase tracking-[0.2em] text-[10px] transition-all duration-500 hover:scale-105 soft-shadow border border-white/10">
                    {buttonText}
                </a>
            </div>
        )}
    </div>
</section>

<style>
    @keyframes heroUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @keyframes heroZoom {
        from { transform: scale(1.1); }
        to { transform: scale(1); }
    }
    .animate-heroUp { animation: heroUp 1.2s cubic-bezier(0.22, 1, 0.36, 1); }
    .animate-heroZoom { animation: heroZoom 20s ease-out forwards; }
    .soft-shadow { box-shadow: 0 20px 50px -10px rgba(184, 134, 11, 0.4); }
</style>
