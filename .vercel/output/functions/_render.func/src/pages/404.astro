---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Forever One | 404 - No Encontrado">
    <Header />
    <main class="min-h-screen flex items-center justify-center bg-black relative overflow-hidden">
        <!-- Background Elements -->
        <div class="absolute inset-0 opacity-10 pointer-events-none">
            <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-gold blur-[150px] rounded-full"></div>
            <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-gold blur-[150px] rounded-full opacity-50"></div>
        </div>

        <div class="relative z-10 text-center px-6" data-aos="zoom-in">
            <h1 class="text-[12rem] md:text-[20rem] font-serif font-black italic text-white/5 tracking-tighter absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 select-none">404</h1>
            
            <img src={`${base}/assets/Foreverone.png`} alt="Forever One Logo" class="h-24 md:h-32 mx-auto mb-12 brightness-0 invert opacity-80">
            
            <h2 class="text-4xl md:text-6xl font-serif font-black italic text-white mb-6">Página No <span class="metal-gold-text">Encontrada</span></h2>
            <p class="text-slate-400 text-sm md:text-lg font-light italic mb-12 max-w-md mx-auto tracking-wide">Lo sentimos, la página que busca no existe o ha sido movida a una colección más exclusiva.</p>
            
            <a href={`${base}`} class="inline-block btn-metal-gold px-12 py-5 text-[10px] uppercase tracking-[0.5em] font-black text-white shadow-2xl hover:scale-105 transition-all">
                Volver al Inicio
            </a>
        </div>
    </main>
    <Footer />
</Layout>

<style>
    .btn-metal-gold {
        background: linear-gradient(135deg, #8B6508 0%, #B8860B 25%, #f3cf7a 50%, #B8860B 75%, #8B6508 100%);
        background-size: 200% auto;
        animation: shine 5s linear infinite;
    }
    @keyframes shine { to { background-position: 200% center; } }
</style>
