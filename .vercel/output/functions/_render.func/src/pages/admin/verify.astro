---
// Página de verificación del código OTP
import { supabase } from '../../lib/supabase';

const url = new URL(Astro.request.url);
const tokenHash = url.searchParams.get('token_hash');
const type = url.searchParams.get('type');

if (tokenHash && type) {
  const { data, error } = await supabase.auth.verifyOtp({
    token_hash: tokenHash,
    type: type as any,
  });

  if (!error && data.session) {
    // Guardar los tokens en cookies seguras
    Astro.cookies.set('sb-access-token', data.session.access_token, {
      path: '/',
      httpOnly: true,
      sameSite: 'lax',
      secure: Astro.url.protocol === 'https:', // Solo usar secure en producción (HTTPS)
      maxAge: 60 * 60 * 24 * 7 // 7 días
    });
    Astro.cookies.set('sb-refresh-token', data.session.refresh_token, {
      path: '/',
      httpOnly: true,
      sameSite: 'lax',
      secure: Astro.url.protocol === 'https:', // Solo usar secure en producción (HTTPS)
      maxAge: 60 * 60 * 24 * 30 // 30 días
    });

    return Astro.redirect('/admin/dashboard');
  }
}

return Astro.redirect('/admin/login?error=invalid_token');
---
