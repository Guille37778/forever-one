---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (!accessToken) return Astro.redirect('/admin/login');
const { data: { user }, error } = await supabase.auth.getUser(accessToken);
if (error || !user) return Astro.redirect('/admin/login');

const { count: totalProducts } = await supabase
  .from('products').select('*', { count: 'exact', head: true });

const { count: lowStock } = await supabase
  .from('variants').select('*', { count: 'exact', head: true }).lt('stock_quantity', 5);

const { count: pendingOrders } = await supabase
  .from('orders').select('*', { count: 'exact', head: true }).eq('status', 'verificando');

const { count: totalSubcategories } = await supabase
  .from('subcategories').select('*', { count: 'exact', head: true });

  const { data: settingsData } = await supabase
    .from('site_settings')
    .select('*')
    .in('key', ['bcv_usd_rate', 'delivery_enabled', 'delivery_zones']);

  const rateData = settingsData?.find(s => s.key === 'bcv_usd_rate');
  const deliveryEnabled = settingsData?.find(s => s.key === 'delivery_enabled')?.value === 'true';
  const deliveryZones = settingsData?.find(s => s.key === 'delivery_zones')?.value || 'Yuma, Güigüe';

const stats = {
  totalProducts: totalProducts || 0,
  pendingOrders: pendingOrders || 0,
  totalRevenue: '$0.00',
  lowStock: lowStock || 0,
  subcategories: totalSubcategories || 0,
  bcvRate: rateData?.value || '0.00',
  lastUpdate: rateData?.updated_at ? new Date(rateData.updated_at).toLocaleString('es-VE') : 'Nunca',
  deliveryEnabled,
  deliveryZones
};
---

<AdminLayout title="Panel Principal" activeNav="dashboard" user={{ email: user.email || '' }}>

  <style>
    .welcome-banner {
      background: linear-gradient(135deg, #0a0a0a 0%, #1a1205 60%, #0a0a0a 100%);
      padding: 2.5rem 3rem;
      margin-bottom: 2.5rem;
      position: relative;
      overflow: hidden;
    }

    .welcome-banner::before {
      content: 'FO1';
      position: absolute;
      right: 2rem;
      top: 50%;
      transform: translateY(-50%);
      font-family: 'Playfair Display', serif;
      font-size: 6rem;
      font-style: italic;
      font-weight: 900;
      color: rgba(184,134,11,0.06);
      letter-spacing: -0.05em;
      pointer-events: none;
      line-height: 1;
    }

    .welcome-label {
      font-size: 8px;
      letter-spacing: 0.5em;
      text-transform: uppercase;
      color: rgba(184,134,11,0.7);
      margin-bottom: 0.75rem;
      font-weight: 600;
    }

    .welcome-title {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      font-weight: 700;
      font-style: italic;
      color: white;
      margin-bottom: 0.5rem;
    }

    .welcome-title span {
      background: linear-gradient(135deg, #B8860B, #f3cf7a, #B8860B);
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shine 4s linear infinite;
    }

    @keyframes shine { to { background-position: 200% center; } }

    .welcome-sub {
      font-size: 11px;
      color: rgba(255,255,255,0.35);
      letter-spacing: 0.05em;
    }

    /* Stats */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.25rem;
      margin-bottom: 2.5rem;
    }

    .stat-card {
      background: white;
      border: 1px solid rgba(0,0,0,0.07);
      padding: 1.75rem 1.5rem;
      transition: box-shadow 0.3s, transform 0.3s;
      position: relative;
      overflow: hidden;
    }

    .stat-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, #B8860B, #f3cf7a, #B8860B);
      background-size: 200% auto;
      animation: shine 3s linear infinite;
    }

    .stat-card:hover {
      box-shadow: 0 12px 40px rgba(0,0,0,0.1);
      transform: translateY(-2px);
    }

    .stat-label {
      font-size: 8px;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: #aaa;
      margin-bottom: 0.875rem;
      font-weight: 600;
    }

    .stat-value {
      font-family: 'Playfair Display', serif;
      font-size: 2.5rem;
      font-weight: 700;
      font-style: italic;
      color: #111;
      line-height: 1;
      margin-bottom: 0.375rem;
    }

    .stat-meta {
      font-size: 9px;
      color: #B8860B;
      font-weight: 500;
      letter-spacing: 0.05em;
    }

    /* Quick Actions */
    .section-label {
      font-size: 8px;
      letter-spacing: 0.5em;
      text-transform: uppercase;
      color: #bbb;
      margin-bottom: 1.25rem;
      font-weight: 600;
    }

    .actions-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    .action-card {
      background: white;
      border: 1px solid rgba(0,0,0,0.07);
      padding: 2rem 1.75rem;
      text-decoration: none;
      color: inherit;
      transition: all 0.3s;
      display: block;
    }

    .action-card:hover {
      border-color: rgba(184,134,11,0.3);
      box-shadow: 0 8px 32px rgba(0,0,0,0.08);
      transform: translateY(-2px);
    }

    .action-icon {
      font-size: 1.75rem;
      margin-bottom: 1rem;
    }

    .action-name {
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #111;
      font-weight: 700;
      margin-bottom: 0.35rem;
    }

    .action-desc {
      font-size: 11px;
      color: #aaa;
    }

    .status-bar {
      background: rgba(184,134,11,0.06);
      border: 1px solid rgba(184,134,11,0.15);
      padding: 1rem 1.5rem;
      font-size: 11px;
      color: #B8860B;
      letter-spacing: 0.05em;
      margin-top: 2.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .status-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #B8860B;
      animation: pulse 2s ease infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.8); }
    }

    /* Rate Card Special */
    .rate-card {
      background: #0a0a0a;
      border: 1px solid rgba(184,134,11,0.3);
      padding: 1.5rem;
      margin-bottom: 2.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: relative;
      overflow: hidden;
    }

    .rate-card::after {
      content: 'BCV';
      position: absolute;
      right: -10px;
      bottom: -20px;
      font-family: 'Playfair Display', serif;
      font-size: 5rem;
      font-weight: 900;
      font-style: italic;
      color: rgba(184,134,11,0.05);
      pointer-events: none;
    }

    .rate-info h3 {
      font-size: 8px;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: #B8860B;
      margin-bottom: 0.5rem;
      font-weight: 700;
    }

    .rate-value {
      font-family: 'Playfair Display', serif;
      font-size: 2.5rem;
      font-weight: 700;
      font-style: italic;
      color: white;
      line-height: 1;
    }

    .rate-value span {
      font-size: 1rem;
      color: rgba(255,255,255,0.4);
      margin-right: 0.5rem;
      font-weight: 400;
    }

    .sync-btn {
      background: transparent;
      border: 1px solid rgba(184,134,11,0.4);
      color: #f3cf7a;
      padding: 0.75rem 1.5rem;
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s;
      z-index: 10;
    }

    .sync-btn:hover {
      background: rgba(184,134,11,0.1);
      border-color: #f3cf7a;
      box-shadow: 0 0 20px rgba(184,134,11,0.2);
    }

    .sync-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    /* Delivery Settings */
    .settings-card {
      background: white;
      border: 1px solid rgba(0,0,0,0.07);
      padding: 2rem;
      margin-bottom: 2.5rem;
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    .form-label {
      display: block;
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: #888;
      margin-bottom: 0.5rem;
      font-weight: 700;
    }

    .form-input {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid #eee;
      font-size: 13px;
      font-family: inherit;
      outline: none;
      transition: border-color 0.3s;
    }

    .form-input:focus {
      border-color: #B8860B;
    }

    .toggle-group {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .save-btn {
      background: #111;
      color: white;
      border: none;
      padding: 0.75rem 2rem;
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: 0.3em;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s;
    }

    .save-btn:hover {
      background: #B8860B;
      box-shadow: 0 4px 15px rgba(184,134,11,0.3);
    }

    @media (max-width: 1024px) {
      .stats-grid {
        grid-template-columns: repeat(2, 1fr);
      }
      .actions-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (max-width: 640px) {
      .welcome-banner {
        padding: 1.5rem;
      }
      .welcome-title {
        font-size: 1.5rem;
      }
      .welcome-banner::before {
        display: none;
      }
      .stats-grid {
        grid-template-columns: 1fr;
      }
      .actions-grid {
        grid-template-columns: 1fr;
      }
      .rate-card {
        flex-direction: column;
        align-items: flex-start;
        gap: 1.5rem;
      }
      .settings-card {
        padding: 1.25rem;
      }
      .status-bar {
        padding: 0.75rem 1rem;
        line-height: 1.4;
      }
    }
  </style>

  <!-- Welcome Banner -->
  <div class="welcome-banner">
    <p class="welcome-label">✦ Atelier Privado</p>
    <h2 class="welcome-title">Bienvenido, <span>Administrador</span></h2>
    <p class="welcome-sub">Sistema Forever One · Todo está bajo control.</p>
  </div>

  <!-- BCV Rate Section -->
  <div class="rate-card">
    <div class="rate-info">
      <h3>Tasa de Cambio Operativa (BCV + 1%)</h3>
      <div class="rate-value"><span>Bs.</span>{stats.bcvRate}</div>
      <p style="font-size: 9px; color: rgba(255,255,255,0.3); margin-top: 0.5rem; letter-spacing: 0.05em;">
        Última actualización: {stats.lastUpdate}
      </p>
    </div>
    <button id="sync-rate-btn" class="sync-btn">
      ↻ Sincronizar Ahora
    </button>
  </div>

  <script>
    import { supabase } from '../../lib/supabase';

    const syncBtn = document.getElementById('sync-rate-btn');
    syncBtn?.addEventListener('click', async () => {
      try {
        if (syncBtn instanceof HTMLButtonElement) {
          syncBtn.disabled = true;
          syncBtn.textContent = '⏱ Sincronizando...';
        }
        
        const response = await fetch('/api/sync-bcv?secret=fo1-secret-bcv-192837');
        const data = await response.json();
        
        if (data.success) {
          window.location.reload();
        } else {
          alert('Error al sincronizar: ' + (data.error || 'Desconocido'));
        }
      } catch (e) {
        console.error(e);
        alert('Error de conexión al sincronizar');
      } finally {
        if (syncBtn instanceof HTMLButtonElement) {
          syncBtn.disabled = false;
          syncBtn.textContent = '↻ Sincronizar Ahora';
        }
      }
    });

    // Delivery Save Logic
    const saveSettingsBtn = document.getElementById('save-settings-btn');
    saveSettingsBtn?.addEventListener('click', async () => {
      try {
        if (saveSettingsBtn instanceof HTMLButtonElement) {
          saveSettingsBtn.disabled = true;
          saveSettingsBtn.textContent = 'Guardando...';
        }

        const enabled = (document.getElementById('delivery-toggle') as HTMLInputElement).checked;
        const zones = (document.getElementById('delivery-zones-input') as HTMLTextAreaElement).value;

        const { error: err1 } = await supabase
          .from('site_settings')
          .upsert({ key: 'delivery_enabled', value: enabled.toString() }, { onConflict: 'key' });

        const { error: err2 } = await supabase
          .from('site_settings')
          .upsert({ key: 'delivery_zones', value: zones }, { onConflict: 'key' });

        if (err1 || err2) throw new Error('Error al guardar en Supabase');
        
        alert('✓ Ajustes de entrega actualizados');
        window.location.reload();
      } catch (e) {
        console.error(e);
        alert('Error al guardar los ajustes');
      } finally {
        if (saveSettingsBtn instanceof HTMLButtonElement) {
          saveSettingsBtn.disabled = false;
          saveSettingsBtn.textContent = 'Guardar Cambios';
        }
      }
    });
  </script>

  <!-- KPI Stats -->
  <div class="stats-grid">
    <div class="stat-card">
      <p class="stat-label">Prendas Activas</p>
      <p class="stat-value">{stats.totalProducts}</p>
      <p class="stat-meta">En catálogo</p>
    </div>
    <div class="stat-card">
      <p class="stat-label">Pedidos Pendientes</p>
      <p class="stat-value">{stats.pendingOrders}</p>
      <p class="stat-meta">Por confirmar</p>
    </div>
    <div class="stat-card">
      <p class="stat-label">Subcategorías</p>
      <p class="stat-value">{stats.subcategories}</p>
      <p class="stat-meta">Clasificaciones</p>
    </div>
    <div class="stat-card">
      <p class="stat-label">Stock Crítico</p>
      <p class="stat-value">{stats.lowStock}</p>
      <p class="stat-meta">Bajo mínimo</p>
    </div>
  </div>

  <!-- Delivery Settings -->
  <p class="section-label">Gestión de Entregas</p>
  <div class="settings-card">
    <div class="toggle-group">
      <input type="checkbox" id="delivery-toggle" checked={stats.deliveryEnabled} class="w-5 h-5 accent-[#B8860B]">
      <label for="delivery-toggle" class="form-label" style="margin-bottom:0">Habilitar Delivery local</label>
    </div>
    
    <div class="form-group">
      <label class="form-label">Zonas de Reparto (Separadas por coma)</label>
      <textarea id="delivery-zones-input" class="form-input" rows="3" placeholder="Ej: Yuma, Güigüe, San Joaquín">{stats.deliveryZones}</textarea>
    </div>

    <button id="save-settings-btn" class="save-btn">Guardar Cambios</button>
  </div>

  <!-- Quick Actions -->
  <p class="section-label">Acciones Rápidas</p>
  <div class="actions-grid">
    <a href="/admin/products/new" class="action-card">
      <div class="action-icon">✦</div>
      <p class="action-name">Nueva Prenda</p>
      <p class="action-desc">Añadir al catálogo exclusivo</p>
    </a>
    <a href="/admin/subcategories" class="action-card">
      <div class="action-icon">◈</div>
      <p class="action-name">Subcategorías</p>
      <p class="action-desc">Gestionar clasificaciones</p>
    </a>
    <a href="/admin/orders" class="action-card">
      <div class="action-icon">📦</div>
      <p class="action-name">Ver Pedidos</p>
      <p class="action-desc">Gestionar órdenes recibidas</p>
    </a>
  </div>

  <!-- Status -->
  <div class="status-bar">
    <div class="status-dot"></div>
    Sistema Forever One — Conectado a Supabase. Todas las funciones operativas.
  </div>

</AdminLayout>
